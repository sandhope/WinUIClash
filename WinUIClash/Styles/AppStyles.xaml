<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 卡片面板：使用 WinUI 内置主题画刷与系统圆角令牌（随主题/对比度变化） -->
    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource OverlayCornerRadius}" />
    </Style>

    <Style x:Key="CardBorderSecondaryStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource OverlayCornerRadius}" />
    </Style>

    <!-- 区块标题：基于 BodyStrong，带上下留白与无障碍层级 -->
    <Style x:Key="SectionHeaderTextBlockStyle"
           BasedOn="{StaticResource BodyStrongTextBlockStyle}"
           TargetType="TextBlock">
        <Setter Property="Margin" Value="0,24,0,8" />
        <Setter Property="AutomationProperties.HeadingLevel" Value="Level2" />
    </Style>

    <!-- 页面主标题 -->
    <Style x:Key="PageTitleTextBlockStyle"
           BasedOn="{StaticResource TitleTextBlockStyle}"
           TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <!-- 间距令牌 -->
    <x:Double x:Key="CardSpacing">12</x:Double>
    <x:Double x:Key="SettingsCardSpacing">4</x:Double>

</ResourceDictionary>
