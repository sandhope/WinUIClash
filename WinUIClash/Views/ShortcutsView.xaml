<UserControl
    x:Class="WinUIClash.Views.ShortcutsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:WinUIClash.Views"
    mc:Ignorable="d">

    <UserControl.Resources>
        <CollectionViewSource
            x:Name="GroupedSource"
            IsSourceGrouped="True"
            ItemsPath="Items"
            Source="{x:Bind Groups}" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Margin="0,0,16,24"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>

                <!-- 表头 -->
                <Grid Padding="16,10"
                      ColumnSpacing="16"
                      Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Source={StaticResource S}, Path=ShortcutColKey_Text}"
                               FontSize="12" FontWeight="SemiBold" Opacity="0.8" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Source={StaticResource S}, Path=ShortcutColDesc_Text}"
                               FontSize="12" FontWeight="SemiBold" Opacity="0.8" />
                </Grid>

                <!-- 分组表格主体 -->
                <ListView ItemsSource="{x:Bind GroupedSource.View, Mode=OneWay}"
                          SelectionMode="None"
                          IsItemClickEnabled="False"
                          Padding="0,0,0,4">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate x:DataType="views:ShortcutGroup">
                                    <TextBlock Text="{x:Bind Name}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                               Margin="16,12,0,4" />
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="views:ShortcutEntry">
                            <Grid ColumnSpacing="16"
                                  Padding="16,8"
                                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                  BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="8,3"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Key}"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind Desc}"
                                           FontSize="13"
                                           Opacity="0.85"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
