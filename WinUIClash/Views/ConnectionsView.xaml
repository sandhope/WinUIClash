<Page
    x:Class="WinUIClash.Views.ConnectionsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fluent="using:FluentIcons.WinUI"
    xmlns:models="using:WinUIClash.Models"
    mc:Ignorable="d">

    <Grid Padding="24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="连接" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            <AutoSuggestBox Grid.Column="1" Margin="16,0"
                            PlaceholderText="搜索连接…"
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.RefreshCommand}" ToolTipService.ToolTip="刷新">
                    <fluent:SymbolIcon Symbol="ArrowSync" FontSize="14" />
                </Button>
                <Button Command="{x:Bind ViewModel.CloseAllCommand}" ToolTipService.ToolTip="关闭全部">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <fluent:SymbolIcon Symbol="DismissCircle" FontSize="14" />
                        <TextBlock Text="关闭全部" FontSize="12" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 连接列表 -->
        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.FilteredConnections, Mode=OneWay}"
                  SelectionMode="Single"
                  SelectedItem="{x:Bind ViewModel.SelectedConnection, Mode=TwoWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ConnectionInfo">
                    <Grid Padding="4,8" ColumnSpacing="12" RowSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- 主机名 -->
                        <TextBlock Text="{x:Bind Metadata.Host}" FontSize="13"
                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />

                        <!-- 上传/下载速度 -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <fluent:SymbolIcon Symbol="ArrowUpload" FontSize="11" Foreground="#4FC3F7" />
                                <TextBlock Text="{x:Bind UploadSpeed, Converter={StaticResource BytesToSpeedConverter}}"
                                           FontSize="11" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <fluent:SymbolIcon Symbol="ArrowDownload" FontSize="11" Foreground="#81C784" />
                                <TextBlock Text="{x:Bind DownloadSpeed, Converter={StaticResource BytesToSpeedConverter}}"
                                           FontSize="11" />
                            </StackPanel>
                        </StackPanel>

                        <!-- 关闭按钮 -->
                        <Button Grid.Column="2" Padding="4"
                                Background="Transparent" BorderThickness="0"
                                ToolTipService.ToolTip="关闭连接"
                                Click="CloseConnection_Click"
                                Tag="{x:Bind}">
                            <fluent:SymbolIcon Symbol="Dismiss" FontSize="12" />
                        </Button>

                        <!-- 详情行 -->
                        <StackPanel Grid.Row="1" Grid.ColumnSpan="3"
                                    Orientation="Horizontal" Spacing="16">
                            <TextBlock FontSize="11" Opacity="0.5">
                                <Run Text="{x:Bind Metadata.Network}" />
                                <Run Text=" · " />
                                <Run Text="{x:Bind Metadata.Process}" />
                                <Run Text=" · " />
                                <Run Text="{x:Bind Rule}" />
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 连接详情面板 -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8"
                Padding="16,12"
                Visibility="{x:Bind ViewModel.SelectedConnection, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
            <Grid ColumnSpacing="24" RowSpacing="8"
                  Visibility="{x:Bind ViewModel.SelectedConnection, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 列 1: 连接基本信息 -->
                <StackPanel Spacing="4">
                    <TextBlock FontSize="11" Opacity="0.5" Text="目标主机" />
                    <TextBlock x:Name="DetailHost" FontSize="13" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="11" Opacity="0.5" Text="源地址" Margin="0,4,0,0" />
                    <TextBlock x:Name="DetailSource" FontSize="12" FontFamily="Consolas" />
                    <TextBlock FontSize="11" Opacity="0.5" Text="目标地址" Margin="0,4,0,0" />
                    <TextBlock x:Name="DetailDest" FontSize="12" FontFamily="Consolas" />
                </StackPanel>

                <!-- 列 2: 流量和代理链 -->
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock FontSize="11" Opacity="0.5" Text="总上传 / 下载" />
                    <TextBlock x:Name="DetailTransfer" FontSize="13" FontWeight="SemiBold" />
                    <TextBlock FontSize="11" Opacity="0.5" Text="代理链" Margin="0,4,0,0" />
                    <TextBlock x:Name="DetailChains" FontSize="12" TextWrapping="Wrap" />
                    <TextBlock FontSize="11" Opacity="0.5" Text="匹配规则" Margin="0,4,0,0" />
                    <TextBlock x:Name="DetailRule" FontSize="12" />
                </StackPanel>

                <!-- 列 3: 时间和操作 -->
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock FontSize="11" Opacity="0.5" Text="开始时间" />
                    <TextBlock x:Name="DetailStart" FontSize="12" />
                    <TextBlock FontSize="11" Opacity="0.5" Text="持续时长" Margin="0,4,0,0" />
                    <TextBlock x:Name="DetailDuration" FontSize="13" FontWeight="SemiBold" />
                    <Button Margin="0,8,0,0"
                            Click="CloseSelected_Click"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <fluent:SymbolIcon Symbol="DismissCircle" FontSize="12" />
                            <TextBlock Text="关闭此连接" FontSize="11" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
