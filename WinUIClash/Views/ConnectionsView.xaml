<Page
    x:Class="WinUIClash.Views.ConnectionsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fluent="using:FluentIcons.WinUI"
    xmlns:models="using:WinUIClash.Models"
    mc:Ignorable="d">

    <Grid Padding="24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Grid RowSpacing="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="{Binding Source={StaticResource S}, Path=ConnTitle_Text}" FontSize="20" FontWeight="SemiBold" />
            <AutoSuggestBox Grid.Row="1" Grid.Column="0" Height="32" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                            PlaceholderText="{Binding Source={StaticResource S}, Path=ConnSearchPlaceholder_PlaceholderText}"
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}" />
            <Button Grid.Row="1" Grid.Column="1" Click="CloseAll_Click" Height="32">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <fluent:SymbolIcon Symbol="DismissCircle" FontSize="14" />
                    <TextBlock Text="{Binding Source={StaticResource S}, Path=ConnCloseAll_Text}" FontSize="12" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- 连接列表 -->
        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.FilteredConnections, Mode=OneWay}"
                  SelectionMode="Single"
                  SelectedItem="{x:Bind ViewModel.SelectedConnection, Mode=TwoWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ConnectionInfo">
                    <Grid Padding="4,8" ColumnSpacing="12" RowSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- 主机名 -->
                        <TextBlock Text="{x:Bind Metadata.Host}" FontSize="13"
                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />

                        <!-- 上传/下载速度 -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <fluent:SymbolIcon Symbol="ArrowUpload" FontSize="11" Foreground="{StaticResource UploadIndicatorBrush}" />
                                <TextBlock Text="{x:Bind UploadSpeed, Converter={StaticResource BytesToSpeedConverter}}"
                                           FontSize="11" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <fluent:SymbolIcon Symbol="ArrowDownload" FontSize="11" Foreground="{StaticResource DownloadIndicatorBrush}" />
                                <TextBlock Text="{x:Bind DownloadSpeed, Converter={StaticResource BytesToSpeedConverter}}"
                                           FontSize="11" />
                            </StackPanel>
                        </StackPanel>

                        <!-- 关闭按钮 -->
                        <Button Grid.Column="2" Padding="4"
                                Background="Transparent" BorderThickness="0"
                                ToolTipService.ToolTip="{Binding Source={StaticResource S}, Path=ConnClose_ToolTip}"
                                Click="CloseConnection_Click"
                                Tag="{x:Bind}">
                            <fluent:SymbolIcon Symbol="Dismiss" FontSize="12" />
                        </Button>

                        <!-- 详情行 -->
                        <StackPanel Grid.Row="1" Grid.ColumnSpan="3"
                                    Orientation="Horizontal" Spacing="16">
                            <TextBlock FontSize="11" Opacity="0.5">
                                <Run Text="{x:Bind Metadata.Network}" />
                                <Run Text=" · " />
                                <Run Text="{x:Bind Metadata.Process}" />
                                <Run Text=" · " />
                                <Run Text="{x:Bind Rule}" />
                            </TextBlock>
                            <TextBlock FontSize="10" Opacity="0.35" VerticalAlignment="Center"
                                       Text="{x:Bind Start, Converter={StaticResource DateTimeToTimeConverter}}"
                                       FontFamily="Consolas" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 空状态 -->
        <StackPanel Grid.Row="1"
                    Visibility="{x:Bind ViewModel.FilteredConnections, Mode=OneWay, Converter={StaticResource EmptyCollectionToVisibilityConverter}}"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
            <fluent:SymbolIcon Symbol="PlugConnected" FontSize="32" Opacity="0.3" />
            <TextBlock Text="{Binding Source={StaticResource S}, Path=EmptyConnections_Text}" Opacity="0.5" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- 连接详情面板 -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8"
                Padding="16,12"
                Visibility="{x:Bind ViewModel.SelectedConnection, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
            <Grid ColumnSpacing="24" RowSpacing="8"
                  Visibility="{x:Bind ViewModel.SelectedConnection, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 列 1: 连接基本信息 -->
                <StackPanel Spacing="4">
                    <TextBlock FontSize="11" Opacity="0.5" Text="{Binding Source={StaticResource S}, Path=ConnDetailHost_Text}" />
                    <TextBlock x:Name="DetailHost" FontSize="13" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="11" Opacity="0.5" Text="{Binding Source={StaticResource S}, Path=ConnDetailSource_Text}" Margin="0,4,0,0" />
                    <TextBlock x:Name="DetailSource" FontSize="12" FontFamily="Consolas" />
                    <TextBlock FontSize="11" Opacity="0.5" Text="{Binding Source={StaticResource S}, Path=ConnDetailDest_Text}" Margin="0,4,0,0" />
                    <TextBlock x:Name="DetailDest" FontSize="12" FontFamily="Consolas" />
                    <TextBlock FontSize="11" Opacity="0.5" Text="{Binding Source={StaticResource S}, Path=ConnDetailProcess_Text}" Margin="0,4,0,0" />
                    <TextBlock x:Name="DetailProcess" FontSize="12" />
                    <TextBlock FontSize="11" Opacity="0.5" Text="{Binding Source={StaticResource S}, Path=ConnDetailDnsMode_Text}" Margin="0,4,0,0" />
                    <TextBlock x:Name="DetailDnsMode" FontSize="12" />
                </StackPanel>

                <!-- 列 2: 流量和代理链 -->
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock FontSize="11" Opacity="0.5" Text="{Binding Source={StaticResource S}, Path=ConnDetailTransfer_Text}" />
                    <TextBlock x:Name="DetailTransfer" FontSize="13" FontWeight="SemiBold" />
                    <TextBlock FontSize="11" Opacity="0.5" Text="{Binding Source={StaticResource S}, Path=ConnChain_Text}" Margin="0,4,0,0" />
                    <TextBlock x:Name="DetailChains" FontSize="12" TextWrapping="Wrap" />
                    <TextBlock FontSize="11" Opacity="0.5" Text="{Binding Source={StaticResource S}, Path=ConnRule_Text}" Margin="0,4,0,0" />
                    <TextBlock x:Name="DetailRule" FontSize="12" />
                    <TextBlock FontSize="11" Opacity="0.5" Text="{Binding Source={StaticResource S}, Path=ConnDetailGeoIP_Text}" Margin="0,4,0,0" />
                    <TextBlock x:Name="DetailGeoIP" FontSize="12" />
                </StackPanel>

                <!-- 列 3: 时间和操作 -->
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock FontSize="11" Opacity="0.5" Text="{Binding Source={StaticResource S}, Path=ConnStartTime_Text}" />
                    <TextBlock x:Name="DetailStart" FontSize="12" />
                    <TextBlock FontSize="11" Opacity="0.5" Text="{Binding Source={StaticResource S}, Path=ConnDuration_Text}" Margin="0,4,0,0" />
                    <TextBlock x:Name="DetailDuration" FontSize="13" FontWeight="SemiBold" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
