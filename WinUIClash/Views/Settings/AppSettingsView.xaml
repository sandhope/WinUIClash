<UserControl
    x:Class="WinUIClash.Views.Settings.AppSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="0,0,16,24">
            <TextBlock Text="应用设置" FontSize="20" FontWeight="SemiBold" />

            <!-- 启动与退出 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="0">
                    <TextBlock Text="启动与退出" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="关闭窗口时最小化" FontSize="13" />
                            <TextBlock Text="不退出程序，最小化到系统托盘" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.MinimizeOnExit, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="开机启动" FontSize="13" />
                            <TextBlock Text="系统启动时自动运行 WinUIClash" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.AutoLaunch, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="静默启动" FontSize="13" />
                            <TextBlock Text="启动时最小化，不显示主窗口" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.SilentLaunch, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="自动运行代理" FontSize="13" />
                            <TextBlock Text="应用启动后自动启动 Clash 核心" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.AutoRun, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 代理行为 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="0">
                    <TextBlock Text="代理行为" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="系统代理" FontSize="13" />
                            <TextBlock Text="自动设置系统 HTTP 代理" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.SystemProxy, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="切换代理时关闭连接" FontSize="13" />
                            <TextBlock Text="切换代理节点时自动关闭已有连接" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.CloseConnections, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="仅统计代理流量" FontSize="13" />
                            <TextBlock Text="仅统计经过代理的流量数据" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.OnlyStatisticsProxy, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 其他 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="自动检查更新" FontSize="13" />
                        <TextBlock Text="启动时自动检查新版本" FontSize="11" Opacity="0.5" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.AutoCheckUpdate, Mode=TwoWay}"
                                  OffContent="" OnContent="" />
                </Grid>
            </Border>

            <!-- 代理绕过 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="8">
                    <StackPanel Spacing="2">
                        <TextBlock Text="代理绕过域名" FontSize="14" />
                        <TextBlock Text="不走代理的地址列表，用分号分隔" FontSize="12" Opacity="0.5" />
                    </StackPanel>
                    <TextBox Text="{x:Bind ViewModel.BypassDomains, Mode=TwoWay}"
                             AcceptsReturn="True" Height="80"
                             TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
