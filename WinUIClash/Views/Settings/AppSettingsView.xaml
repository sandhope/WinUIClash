<UserControl
    x:Class="WinUIClash.Views.Settings.AppSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fluent="using:FluentIcons.WinUI"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="0,0,16,24">
            <!-- 启动与退出 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="0">
                    <TextBlock Text="{Binding Source={StaticResource S}, Path=AppStartupExit_Text}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=AppMinimizeOnExit_Text}" FontSize="13" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=AppMinimizeOnExitDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.MinimizeOnExit, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=AppAutoLaunch_Text}" FontSize="13" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=AppAutoLaunchDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.AutoLaunch, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=AppSilentLaunch_Text}" FontSize="13" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=AppSilentLaunchDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.SilentLaunch, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=AppAutoRun_Text}" FontSize="13" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=AppAutoRunDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.AutoRun, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=AppAutoRestart_Text}" FontSize="13" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=AppAutoRestartDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.AutoRestart, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 代理行为 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="0">
                    <TextBlock Text="{Binding Source={StaticResource S}, Path=AppProxyBehavior_Text}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=AppSystemProxy_Text}" FontSize="13" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=AppSystemProxyDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.SystemProxy, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=AppProxyGuard_Text}" FontSize="13" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=AppProxyGuardDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.ProxyGuardEnabled, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=AppProxyGuardInterval_Text}" FontSize="13" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=AppProxyGuardIntervalDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <NumberBox Grid.Column="1" Value="{x:Bind ViewModel.ProxyGuardInterval, Mode=TwoWay}"
                                   Minimum="5" Maximum="600" SmallChange="5" LargeChange="30"
                                   SpinButtonPlacementMode="Compact" MinWidth="120" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=AppTunMode_Text}" FontSize="13" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=AppTunModeDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.TunMode, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=AppTunStack_Text}" FontSize="13" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=AppTunStackDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ComboBox Grid.Column="1" Width="120"
                                  ItemsSource="{x:Bind ViewModel.TunStackOptions}"
                                  SelectedItem="{x:Bind ViewModel.TunStack, Mode=TwoWay}" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=AppCloseConnections_Text}" FontSize="13" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=AppCloseConnectionsDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.CloseConnections, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=AppOnlyStatisticsProxy_Text}" FontSize="13" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=AppOnlyStatisticsProxyDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.OnlyStatisticsProxy, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 其他 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="0">
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=AppAutoCheckUpdate_Text}" FontSize="13" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=AppAutoCheckUpdateDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.AutoCheckUpdate, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=AppShowNotifications_Text}" FontSize="13" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=AppShowNotificationsDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.ShowNotifications, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 代理绕过 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=AppBypassDomains_Text}" FontSize="14" />
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=AppBypassDomainsDesc_Text}" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Padding="8,4" Background="Transparent" BorderThickness="0"
                                Click="BypassPresets_Click">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <SymbolIcon Symbol="List" />
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=AppBypassPresets_Text}" FontSize="11" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBox x:Name="BypassTextBox"
                             Text="{x:Bind ViewModel.BypassDomains, Mode=TwoWay}"
                             AcceptsReturn="True" Height="80"
                             TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- 备份/恢复 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding Source={StaticResource S}, Path=SettingsBackup_Text}" FontSize="14" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="ExportSettings_Click" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <fluent:SymbolIcon Symbol="ArrowExport" FontSize="14" />
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=SettingsExportSettings_Text}" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button Click="ImportSettings_Click" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <fluent:SymbolIcon Symbol="ArrowImport" FontSize="14" />
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=SettingsImportSettings_Text}" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
