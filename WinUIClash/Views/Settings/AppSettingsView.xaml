<UserControl
    x:Class="WinUIClash.Views.Settings.AppSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fluent="using:FluentIcons.WinUI"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="0,0,16,24">
            <TextBlock x:Uid="SettingsApp" FontSize="20" FontWeight="SemiBold" />

            <!-- 语言 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock x:Uid="AppLanguage" FontSize="13" />
                        <TextBlock x:Uid="AppLanguageSwitchDesc" FontSize="11" Opacity="0.5" />
                    </StackPanel>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{x:Bind ViewModel.Languages}"
                              SelectedValue="{x:Bind ViewModel.Language, Mode=TwoWay}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="Label"
                              MinWidth="140" />
                </Grid>
            </Border>

            <!-- 启动与退出 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="0">
                    <TextBlock x:Uid="AppStartupExit" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="AppMinimizeOnExit" FontSize="13" />
                            <TextBlock x:Uid="AppMinimizeOnExitDesc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.MinimizeOnExit, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="AppAutoLaunch" FontSize="13" />
                            <TextBlock x:Uid="AppAutoLaunchDesc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.AutoLaunch, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="AppSilentLaunch" FontSize="13" />
                            <TextBlock x:Uid="AppSilentLaunchDesc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.SilentLaunch, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="AppAutoRun" FontSize="13" />
                            <TextBlock x:Uid="AppAutoRunDesc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.AutoRun, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="AppAutoRestart" FontSize="13" />
                            <TextBlock x:Uid="AppAutoRestartDesc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.AutoRestart, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 代理行为 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="0">
                    <TextBlock x:Uid="AppProxyBehavior" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="AppSystemProxy" FontSize="13" />
                            <TextBlock x:Uid="AppSystemProxyDesc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.SystemProxy, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="AppProxyGuard" FontSize="13" />
                            <TextBlock x:Uid="AppProxyGuardDesc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.ProxyGuardEnabled, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="AppProxyGuardInterval" FontSize="13" />
                            <TextBlock x:Uid="AppProxyGuardIntervalDesc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <NumberBox Grid.Column="1" Value="{x:Bind ViewModel.ProxyGuardInterval, Mode=TwoWay}"
                                   Minimum="5" Maximum="600" SmallChange="5" LargeChange="30"
                                   SpinButtonPlacementMode="Compact" MinWidth="120" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="AppTunMode" FontSize="13" />
                            <TextBlock x:Uid="AppTunModeDesc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.TunMode, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="AppTunStack" FontSize="13" />
                            <TextBlock x:Uid="AppTunStackDesc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ComboBox Grid.Column="1" Width="120"
                                  ItemsSource="{x:Bind ViewModel.TunStackOptions}"
                                  SelectedItem="{x:Bind ViewModel.TunStack, Mode=TwoWay}" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="AppCloseConnections" FontSize="13" />
                            <TextBlock x:Uid="AppCloseConnectionsDesc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.CloseConnections, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="AppOnlyStatisticsProxy" FontSize="13" />
                            <TextBlock x:Uid="AppOnlyStatisticsProxyDesc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.OnlyStatisticsProxy, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 其他 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="0">
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="AppAutoCheckUpdate" FontSize="13" />
                            <TextBlock x:Uid="AppAutoCheckUpdateDesc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.AutoCheckUpdate, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="AppShowNotifications" FontSize="13" />
                            <TextBlock x:Uid="AppShowNotificationsDesc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.ShowNotifications, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 代理绕过 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock x:Uid="AppBypassDomains" FontSize="14" />
                            <TextBlock x:Uid="AppBypassDomainsDesc" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                        <Button Grid.Column="1" x:Uid="AppBypassPresets"
                                Padding="8,4" Background="Transparent" BorderThickness="0"
                                Click="BypassPresets_Click">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <SymbolIcon Symbol="List" />
                                <TextBlock x:Uid="AppBypassPresets" FontSize="11" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBox x:Name="BypassTextBox"
                             Text="{x:Bind ViewModel.BypassDomains, Mode=TwoWay}"
                             AcceptsReturn="True" Height="80"
                             TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- 备份/恢复 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="SettingsBackup" FontSize="14" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Uid="SettingsExportSettings" Click="ExportSettings_Click" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <fluent:SymbolIcon Symbol="ArrowExport" FontSize="14" />
                                <TextBlock x:Uid="SettingsExportSettings" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button x:Uid="SettingsImportSettings" Click="ImportSettings_Click" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <fluent:SymbolIcon Symbol="ArrowImport" FontSize="14" />
                                <TextBlock x:Uid="SettingsImportSettings" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
