<UserControl
    x:Class="WinUIClash.Views.Settings.AboutView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fluent="using:FluentIcons.WinUI"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="0,0,16,24">
            <TextBlock x:Uid="AboutTitle" FontSize="20" FontWeight="SemiBold" />

            <!-- 应用信息 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="12" HorizontalAlignment="Center" Padding="24">
                    <fluent:SymbolIcon Symbol="Shield" FontSize="48" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                    <TextBlock Text="WinUIClash" FontSize="20" FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Uid="AboutVersion" FontSize="12" Opacity="0.5"
                               x:Name="VersionText"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Uid="AboutDescription"
                               FontSize="12" Opacity="0.6" HorizontalAlignment="Center"
                               TextAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- 技术栈 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="AboutTechStack" FontSize="14" FontWeight="SemiBold" />
                    <Grid ColumnSpacing="12" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Uid="AboutFramework" Opacity="0.5" FontSize="12" />
                        <TextBlock Grid.Column="1" Text=".NET 10 + Windows App SDK 2.2" FontSize="12" />
                        <TextBlock Grid.Row="1" Text="UI" Opacity="0.5" FontSize="12" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="WinUI 3 (XAML) + Mica" FontSize="12" />
                        <TextBlock Grid.Row="2" Text="MVVM" Opacity="0.5" FontSize="12" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="CommunityToolkit.Mvvm 8.4" FontSize="12" />
                        <TextBlock Grid.Row="3" x:Uid="AboutCore" Opacity="0.5" FontSize="12" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="ClashMeta (Mihomo)" FontSize="12" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 链接 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="4">
                    <HyperlinkButton x:Uid="AboutFlClash" NavigateUri="https://github.com/chen08209/FlClash" />
                    <HyperlinkButton x:Uid="AboutMihomo" NavigateUri="https://github.com/MetaCubeX/mihomo" />
                    <HyperlinkButton x:Uid="AboutWinAppSdk" NavigateUri="https://learn.microsoft.com/windows/apps/winui/" />
                </StackPanel>
            </Border>

            <!-- 操作 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="AboutActions" FontSize="14" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="OpenDataFolder_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <fluent:SymbolIcon Symbol="FolderOpen" FontSize="14" />
                                <TextBlock x:Uid="AboutOpenDataFolder" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button Click="CopyVersion_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <fluent:SymbolIcon Symbol="Copy" FontSize="14" />
                                <TextBlock x:Uid="AboutCopyVersion" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="CheckUpdateBtn" Click="CheckUpdate_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Grid Width="14" Height="14">
                                    <fluent:SymbolIcon x:Name="UpdateIcon" Symbol="ArrowSync" FontSize="14" />
                                    <ProgressRing x:Name="UpdateProgressRing" IsActive="False"
                                                  Width="14" Height="14" Visibility="Collapsed" />
                                </Grid>
                                <TextBlock x:Name="CheckUpdateLabel" x:Uid="AboutCheckUpdate" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button Click="ExportLogs_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <fluent:SymbolIcon Symbol="ArrowExport" FontSize="14" />
                                <TextBlock x:Uid="AboutExportLogs" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBlock x:Name="UpdateStatusText" FontSize="11" Opacity="0.6"
                               Visibility="Collapsed" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- 许可证 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <TextBlock FontSize="11" Opacity="0.4" TextWrapping="Wrap"
                           x:Uid="AboutLicense" />
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
