<UserControl
    x:Class="WinUIClash.Views.Settings.BasicConfigView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="0,0,16,24">
            <TextBlock x:Uid="SettingsBasicConfig" FontSize="20" FontWeight="SemiBold" />

            <!-- 端口 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="ConfigPortSettings" FontSize="14" FontWeight="SemiBold" />
                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Uid="ConfigPort" VerticalAlignment="Center" />
                        <NumberBox Grid.Column="1" Value="{x:Bind ViewModel.MixedPort, Mode=TwoWay}"
                                   Minimum="1024" Maximum="65535" SmallChange="1" />
                        <TextBlock Grid.Column="2" x:Uid="ConfigSocksPort" VerticalAlignment="Center" />
                        <NumberBox Grid.Column="3" Value="{x:Bind ViewModel.SocksPort, Mode=TwoWay}"
                                   Minimum="1024" Maximum="65535" SmallChange="1" />
                        <TextBlock Grid.Row="1" x:Uid="ConfigHttpPort" VerticalAlignment="Center" />
                        <NumberBox Grid.Row="1" Grid.Column="1" Value="{x:Bind ViewModel.HttpPort, Mode=TwoWay}"
                                   Minimum="1024" Maximum="65535" SmallChange="1" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 日志级别 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock x:Uid="ConfigLogLevel" FontSize="14" />
                        <TextBlock x:Uid="ConfigLogLevelDesc" FontSize="12" Opacity="0.5" />
                    </StackPanel>
                    <ComboBox Grid.Column="1" Width="140"
                              ItemsSource="{x:Bind ViewModel.LogLevelOptions}"
                              SelectedItem="{x:Bind ViewModel.LogLevel, Mode=TwoWay}" />
                </Grid>
            </Border>

            <!-- User-Agent -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock x:Uid="ConfigUserAgent" FontSize="14" />
                        <TextBlock x:Uid="ConfigUserAgentDesc" FontSize="12" Opacity="0.5" />
                    </StackPanel>
                    <ComboBox Grid.Column="1" Width="180"
                              ItemsSource="{x:Bind ViewModel.UserAgentOptions}"
                              SelectedItem="{x:Bind ViewModel.UserAgent, Mode=TwoWay}" />
                </Grid>
            </Border>

            <!-- Keep-Alive -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock x:Uid="ConfigKeepAlive" FontSize="14" />
                        <TextBlock x:Uid="ConfigKeepAliveDesc" FontSize="12" Opacity="0.5" />
                    </StackPanel>
                    <NumberBox Grid.Column="1" Width="100"
                               Value="{x:Bind ViewModel.KeepAliveInterval, Mode=TwoWay}"
                               Minimum="0" Maximum="300" SmallChange="5" />
                </Grid>
            </Border>

            <!-- 测速 URL -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="8">
                    <StackPanel Spacing="2">
                        <TextBlock x:Uid="ConfigTestUrl" FontSize="14" />
                        <TextBlock x:Uid="ConfigTestUrlDesc" FontSize="12" Opacity="0.5" />
                    </StackPanel>
                    <TextBox Text="{x:Bind ViewModel.TestUrl, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <!-- 功能开关 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="0">
                    <TextBlock x:Uid="ConfigFeatureSwitches" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <!-- IPv6 -->
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="ConfigIpv6" FontSize="13" />
                            <TextBlock x:Uid="ConfigIpv6Desc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.Ipv6, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <!-- Allow LAN -->
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="ConfigAllowLan" FontSize="13" />
                            <TextBlock x:Uid="ConfigAllowLanDesc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.AllowLan, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <!-- Unified Delay -->
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="ConfigUnifiedDelay" FontSize="13" />
                            <TextBlock x:Uid="ConfigUnifiedDelayDesc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.UnifiedDelay, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <!-- TCP Concurrent -->
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="ConfigTcpConcurrent" FontSize="13" />
                            <TextBlock x:Uid="ConfigTcpConcurrentDesc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.TcpConcurrent, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <!-- Find Process -->
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="ConfigFindProcess" FontSize="13" />
                            <TextBlock x:Uid="ConfigFindProcessDesc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.FindProcessMode, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <!-- External Controller -->
                    <Grid Padding="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Uid="ConfigExternalController" FontSize="13" />
                            <TextBlock x:Uid="ConfigExternalControllerDesc" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.ExternalController, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
