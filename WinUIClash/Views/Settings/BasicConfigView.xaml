<UserControl
    x:Class="WinUIClash.Views.Settings.BasicConfigView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="0,0,16,24">
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigPortSettings_Text}" FontSize="14" FontWeight="SemiBold" />
                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigPort_Text}" VerticalAlignment="Center" />
                        <NumberBox Grid.Column="1" Value="{x:Bind ViewModel.MixedPort, Mode=TwoWay}"
                                   Minimum="1024" Maximum="65535" SmallChange="1" />
                        <TextBlock Grid.Column="2" Text="{Binding Source={StaticResource S}, Path=ConfigSocksPort_Text}" VerticalAlignment="Center" />
                        <NumberBox Grid.Column="3" Value="{x:Bind ViewModel.SocksPort, Mode=TwoWay}"
                                   Minimum="1024" Maximum="65535" SmallChange="1" />
                        <TextBlock Grid.Row="1" Text="{Binding Source={StaticResource S}, Path=ConfigHttpPort_Text}" VerticalAlignment="Center" />
                        <NumberBox Grid.Row="1" Grid.Column="1" Value="{x:Bind ViewModel.HttpPort, Mode=TwoWay}"
                                   Minimum="1024" Maximum="65535" SmallChange="1" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigLogLevel_Text}" FontSize="14" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigLogLevelDesc_Text}" FontSize="12" Opacity="0.5" />
                    </StackPanel>
                    <ComboBox Grid.Column="1" Width="140"
                              ItemsSource="{x:Bind ViewModel.LogLevelOptions}"
                              SelectedItem="{x:Bind ViewModel.LogLevel, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource SettingsCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigUserAgent_Text}" FontSize="14" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigUserAgentDesc_Text}" FontSize="12" Opacity="0.5" />
                    </StackPanel>
                    <ComboBox Grid.Column="1" Width="180"
                              ItemsSource="{x:Bind ViewModel.UserAgentOptions}"
                              SelectedItem="{x:Bind ViewModel.UserAgent, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource SettingsCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigKeepAlive_Text}" FontSize="14" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigKeepAliveDesc_Text}" FontSize="12" Opacity="0.5" />
                    </StackPanel>
                    <NumberBox Grid.Column="1" Width="100"
                               Value="{x:Bind ViewModel.KeepAliveInterval, Mode=TwoWay}"
                               Minimum="0" Maximum="300" SmallChange="5" />
                </Grid>
            </Border>

            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="8">
                    <StackPanel Spacing="2">
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigTestUrl_Text}" FontSize="14" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigTestUrlDesc_Text}" FontSize="12" Opacity="0.5" />
                    </StackPanel>
                    <TextBox Text="{x:Bind ViewModel.TestUrl, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="8">
                    <StackPanel Spacing="2">
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigCoreBinaryPath_Text}" FontSize="14" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigCoreBinaryPathDesc_Text}" FontSize="12" Opacity="0.5" />
                    </StackPanel>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{x:Bind ViewModel.CoreBinaryPath, Mode=TwoWay}"
                                 PlaceholderText="{Binding Source={StaticResource S}, Path=ConfigCoreBinaryPathPlaceholder_PlaceholderText}" />
                        <Button Grid.Column="1" Content="{Binding Source={StaticResource S}, Path=ConfigBrowse_Content}"
                                Click="BrowseCoreBinary_Click"
                                Padding="12,6" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="0">
                    <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigFeatureSwitches_Text}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigClipboardDetect_Text}" FontSize="13" />
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigClipboardDetectDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.EnableClipboardDetection, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigIpv6_Text}" FontSize="13" />
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigIpv6Desc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.Ipv6, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigAllowLan_Text}" FontSize="13" />
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigAllowLanDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.AllowLan, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigUnifiedDelay_Text}" FontSize="13" />
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigUnifiedDelayDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.UnifiedDelay, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigTcpConcurrent_Text}" FontSize="13" />
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigTcpConcurrentDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.TcpConcurrent, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigFindProcess_Text}" FontSize="13" />
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigFindProcessDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ComboBox Grid.Column="1" Width="120"
                                  ItemsSource="{x:Bind ViewModel.FindProcessModeOptions}"
                                  SelectedItem="{x:Bind ViewModel.FindProcessMode, Mode=TwoWay}" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigExternalController_Text}" FontSize="13" />
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigExternalControllerDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.ExternalController, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                    <Grid Padding="0,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigApiSecret_Text}" FontSize="13" />
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigApiSecretDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <TextBox Grid.Column="1" Width="200"
                                 Text="{x:Bind ViewModel.ApiSecret, Mode=TwoWay}"
                                 PlaceholderText="{Binding Source={StaticResource S}, Path=ConfigApiSecretPlaceholder_PlaceholderText}" />
                    </Grid>
                    <Grid Padding="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigAutoRestart_Text}" FontSize="13" />
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=ConfigAutoRestartDesc_Text}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.AutoRestart, Mode=TwoWay}"
                                      OffContent="" OnContent="" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>