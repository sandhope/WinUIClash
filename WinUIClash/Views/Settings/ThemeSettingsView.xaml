<UserControl
    x:Class="WinUIClash.Views.Settings.ThemeSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="0,0,16,24">
            <TextBlock x:Uid="SettingsTheme" FontSize="20" FontWeight="SemiBold" />

            <!-- 主题模式 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="ThemeMode" FontSize="14" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <RadioButton x:Uid="ThemeSystem" GroupName="ThemeMode"
                                     IsChecked="{x:Bind ViewModel.IsSystemTheme, Mode=TwoWay}" />
                        <RadioButton x:Uid="ThemeLight" GroupName="ThemeMode"
                                     IsChecked="{x:Bind ViewModel.IsLightTheme, Mode=TwoWay}" />
                        <RadioButton x:Uid="ThemeDark" GroupName="ThemeMode"
                                     IsChecked="{x:Bind ViewModel.IsDarkTheme, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 主题色 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="ThemeAccentColor" FontSize="14" FontWeight="SemiBold" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.PrimaryColors}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="48" MinItemHeight="48"
                                               MinRowSpacing="8" MinColumnSpacing="8"
                                               MaximumRowsOrColumns="8" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Button Width="48" Height="48" Padding="0"
                                        Tag="{Binding}" Click="Color_Click"
                                        ToolTipService.ToolTip="{Binding Name}">
                                    <Button.Background>
                                        <SolidColorBrush Color="{Binding Hex, Converter={StaticResource HexToColorConverter}}" />
                                    </Button.Background>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
