<Page
    x:Class="WinUIClash.Views.LogsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fluent="using:FluentIcons.WinUI"
    xmlns:models="using:WinUIClash.Models"
    mc:Ignorable="d">

    <Grid Padding="24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏：搜索 + 自动滚动 + 导出 -->
        <Grid RowSpacing="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="{Binding Source={StaticResource S}, Path=LogsTitle_Text}" FontSize="20" FontWeight="SemiBold" />
            <AutoSuggestBox Grid.Row="1" Grid.Column="0" Height="32" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                            PlaceholderText="{Binding Source={StaticResource S}, Path=LogsSearchPlaceholder_PlaceholderText}"
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}" />
            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="{Binding Source={StaticResource S}, Path=LogsAutoScroll_Text}" FontSize="11" VerticalAlignment="Center" />
                <ToggleSwitch MinWidth="0" OffContent="" OnContent=""
                              IsOn="{x:Bind ViewModel.AutoScroll, Mode=TwoWay}" />
            </StackPanel>
            <Button Grid.Row="1" Grid.Column="2"
                    Command="{x:Bind ViewModel.ExportCommand}"
                    ToolTipService.ToolTip="{Binding Source={StaticResource S}, Path=LogsExport_ToolTip}"
                    Height="32">
                <fluent:SymbolIcon Symbol="Save" FontSize="14" />
            </Button>
        </Grid>

        <!-- 日志列表 -->
        <ListView x:Name="LogList" Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.FilteredLogs, Mode=OneWay}"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:LogEntry">
                    <Grid Padding="4,6" ColumnSpacing="10" Tag="{x:Bind}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!-- 时间戳 -->
                        <TextBlock Text="{x:Bind Timestamp, Converter={StaticResource DateTimeToTimeConverter}}"
                                   FontSize="11" Opacity="0.5" FontFamily="Consolas"
                                   VerticalAlignment="Center" Width="65" />
                        <!-- 级别标签 -->
                        <Border Grid.Column="1" CornerRadius="3" Padding="6,2"
                                VerticalAlignment="Center"
                                Tapped="LogLevelBadge_Tapped"
                                Tag="{x:Bind Level}">
                            <Border.Background>
                                <SolidColorBrush Color="{ThemeResource SubtleFillColorSecondary}" />
                            </Border.Background>
                            <TextBlock Text="{x:Bind Level}" FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{x:Bind Level, Converter={StaticResource LogLevelToColorConverter}}" />
                        </Border>
                        <!-- 内容 -->
                        <TextBlock Grid.Column="2" Text="{x:Bind Payload}" FontSize="12"
                                   FontFamily="Consolas"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 空状态 -->
        <StackPanel Grid.Row="1"
                    Visibility="{x:Bind ViewModel.FilteredLogs, Mode=OneWay, Converter={StaticResource EmptyCollectionToVisibilityConverter}}"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
            <fluent:SymbolIcon Symbol="DocumentBulletList" FontSize="32" Opacity="0.3" />
            <TextBlock Text="{Binding Source={StaticResource S}, Path=EmptyLogs_Text}" Opacity="0.5" HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>
