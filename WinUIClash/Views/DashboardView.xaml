<Page
    x:Class="WinUIClash.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fluent="using:FluentIcons.WinUI"
    xmlns:vm="using:WinUIClash.ViewModels"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16">
        <Grid RowSpacing="16" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ═══ 第一行：状态栏 + 网速图表 ═══ -->

            <!-- 核心状态卡片 -->
            <Border Grid.Row="0" Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="10" Height="10" Fill="{x:Bind ViewModel.StatusBrush, Mode=OneWay}" />
                        <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" FontWeight="SemiBold" />
                    </StackPanel>
                    <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.RuntimeText, Mode=OneWay}"
                               FontSize="12" Opacity="0.6" Margin="0,8,0,0" />
                    <Button Grid.Row="2" Margin="0,12,0,0"
                            Content="{x:Bind ViewModel.CoreToggleText, Mode=OneWay}"
                            Command="{x:Bind ViewModel.ToggleCoreCommand}"
                            HorizontalAlignment="Stretch" />
                </Grid>
            </Border>

            <!-- 网速实时图表 (占3列) -->
            <Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <!-- 速度标签 -->
                    <StackPanel Orientation="Horizontal" Spacing="24">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fluent:SymbolIcon Symbol="ArrowUpload" FontSize="14" Foreground="{StaticResource UploadIndicatorBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.UploadSpeed, Mode=OneWay}" FontSize="13" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fluent:SymbolIcon Symbol="ArrowDownload" FontSize="14" Foreground="{StaticResource DownloadIndicatorBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.DownloadSpeed, Mode=OneWay}" FontSize="13" />
                        </StackPanel>
                    </StackPanel>
                    <!-- 简易面积图 -->
                    <Canvas x:Name="SpeedChart" Grid.Row="1" Height="120" Margin="0,8,0,0"
                            SizeChanged="SpeedChart_SizeChanged"
                            PointerMoved="SpeedChart_PointerMoved"
                            PointerExited="SpeedChart_PointerExited" />
                </Grid>
            </Border>

            <!-- ═══ 第二行：出站模式 + 流量统计 + 网络检测 + 内网IP ═══ -->

            <!-- 出站模式 -->
            <Border Grid.Row="1" Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Uid="DashOutboundMode" FontWeight="SemiBold" FontSize="13" Opacity="0.8" />
                    <RadioButton Grid.Row="1" x:Uid="DashModeRule" GroupName="Mode"
                                 IsChecked="{x:Bind ViewModel.IsModeRule, Mode=TwoWay}" />
                    <RadioButton Grid.Row="2" x:Uid="DashModeGlobal" GroupName="Mode"
                                 IsChecked="{x:Bind ViewModel.IsModeGlobal, Mode=TwoWay}" />
                    <RadioButton Grid.Row="3" x:Uid="DashModeDirect" GroupName="Mode"
                                 IsChecked="{x:Bind ViewModel.IsModeDirect, Mode=TwoWay}" />
                </Grid>
            </Border>

            <!-- 流量统计 -->
            <Border Grid.Row="1" Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Uid="DashTrafficStats" FontWeight="SemiBold" FontSize="13" Opacity="0.8" />
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <fluent:SymbolIcon Symbol="ArrowUpload" FontSize="14" Foreground="{StaticResource UploadIndicatorBrush}" />
                        <TextBlock x:Uid="DashUploadSpeed" FontSize="12" Opacity="0.7" />
                        <TextBlock Text="{x:Bind ViewModel.TotalUpload, Mode=OneWay}" FontWeight="SemiBold" Margin="8,0,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                        <fluent:SymbolIcon Symbol="ArrowDownload" FontSize="14" Foreground="{StaticResource DownloadIndicatorBrush}" />
                        <TextBlock x:Uid="DashDownloadSpeed" FontSize="12" Opacity="0.7" />
                        <TextBlock Text="{x:Bind ViewModel.TotalDownload, Mode=OneWay}" FontWeight="SemiBold" Margin="8,0,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                        <fluent:SymbolIcon Symbol="Link" FontSize="14" Opacity="0.6" />
                        <TextBlock x:Uid="DashActiveConnections" FontSize="12" Opacity="0.7" />
                        <TextBlock Text="{x:Bind ViewModel.ActiveConnections, Mode=OneWay}" FontWeight="SemiBold" Margin="8,0,0,0" />
                    </StackPanel>
                    <HyperlinkButton Grid.Row="4" x:Uid="DashResetTraffic" FontSize="12" Padding="0" Margin="0,4,0,0"
                                     Command="{x:Bind ViewModel.ResetTrafficCommand}" />
                </Grid>
            </Border>

            <!-- 网络检测 -->
            <Border Grid.Row="1" Grid.Column="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Uid="DashNetworkInfo" FontWeight="SemiBold" FontSize="13" Opacity="0.8" />
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <TextBlock Text="{x:Bind ViewModel.CountryFlag, Mode=OneWay}" FontSize="24" />
                        <TextBlock Text="{x:Bind ViewModel.ExternalIp, Mode=OneWay}"
                                   VerticalAlignment="Center" FontSize="13" />
                    </StackPanel>
                    <Button Grid.Row="2" x:Uid="DashCheckIp" FontSize="12"
                            Command="{x:Bind ViewModel.CheckIpCommand}"
                            HorizontalAlignment="Stretch" Margin="0,4,0,0" />
                    <!-- DNS 查询 -->
                    <Grid Grid.Row="3" ColumnSpacing="6" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Uid="DashDnsPlaceholder"
                                 Text="{x:Bind ViewModel.DnsQueryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="12" />
                        <ComboBox Grid.Column="1" SelectedItem="{x:Bind ViewModel.DnsQueryType, Mode=TwoWay}"
                                  ItemsSource="{x:Bind ViewModel.DnsTypeOptions}"
                                  FontSize="11" Width="70" />
                        <Button Grid.Column="2" Padding="8,4"
                                Command="{x:Bind ViewModel.QueryDnsCommand}">
                            <fluent:SymbolIcon Symbol="Search" FontSize="13" />
                        </Button>
                    </Grid>
                    <TextBlock Grid.Row="4"
                               Text="{x:Bind ViewModel.DnsResult, Mode=OneWay}"
                               FontSize="11" FontFamily="Consolas"
                               TextWrapping="Wrap" Opacity="0.7"
                               MaxHeight="60"
                               IsTextSelectionEnabled="True" />
                </Grid>
            </Border>

            <!-- 内网 IP + 内存 + 核心版本 -->
            <Border Grid.Row="1" Grid.Column="3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Uid="DashSystemInfo" FontWeight="SemiBold" FontSize="13" Opacity="0.8" />
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <fluent:SymbolIcon Symbol="Wifi1" FontSize="14" Opacity="0.6" />
                        <TextBlock x:Uid="DashLocalIp" FontSize="12" Opacity="0.7" />
                        <TextBlock Text="{x:Bind ViewModel.LocalIp, Mode=OneWay}" FontSize="13" Margin="8,0,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                        <fluent:SymbolIcon Symbol="Storage" FontSize="14" Opacity="0.6" />
                        <TextBlock x:Uid="DashCoreMemory" FontSize="12" Opacity="0.7" />
                        <TextBlock Text="{x:Bind ViewModel.CoreMemory, Mode=OneWay}" FontSize="13" Margin="8,0,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                        <fluent:SymbolIcon Symbol="Info" FontSize="14" Opacity="0.6" />
                        <TextBlock x:Uid="DashCoreVersion" FontSize="12" Opacity="0.7" />
                        <TextBlock Text="{x:Bind ViewModel.CoreVersion, Mode=OneWay}" FontSize="12" Margin="8,0,0,0"
                                   FontFamily="Consolas" TextTrimming="CharacterEllipsis" MaxWidth="140" />
                    </StackPanel>
                    <Grid Grid.Row="4" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Uid="DashRefreshMemory" FontSize="12"
                                Command="{x:Bind ViewModel.RefreshMemoryCommand}"
                                HorizontalAlignment="Stretch" />
                        <Button Grid.Column="1" x:Uid="DashForceGc" FontSize="12"
                                Command="{x:Bind ViewModel.ForceGcCommand}"
                                HorizontalAlignment="Stretch" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
