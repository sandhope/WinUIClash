<Page
    x:Class="WinUIClash.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fluent="using:FluentIcons.WinUI"
    xmlns:vm="using:WinUIClash.ViewModels"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- 卡片标题样式 -->
        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Opacity" Value="0.8" />
        </Style>
        <!-- 小标签样式 -->
        <Style x:Key="CardLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Opacity" Value="0.7" />
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16,24,96">
            <Grid RowSpacing="16" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ═══ 第一行：左侧网速图（宽） + 右侧系统代理/虚拟网卡（窄堆叠） ═══ -->

                <!-- 网络速度图表（占 ~66%） -->
                <Border Grid.Row="0" Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20,16,20,16"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <Grid RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- 标题栏：网络速度 | 速度数值 -->
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <fluent:SymbolIcon Symbol="Gauge" FontSize="14" Opacity="0.7" />
                                <TextBlock Text="网络速度" FontWeight="SemiBold" FontSize="14" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="18" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <fluent:SymbolIcon Symbol="ArrowUpload" FontSize="12" Foreground="{StaticResource UploadIndicatorBrush}" />
                                    <TextBlock Text="{x:Bind ViewModel.UploadSpeed, Mode=OneWay}" FontSize="13" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <fluent:SymbolIcon Symbol="ArrowDownload" FontSize="12" Foreground="{StaticResource DownloadIndicatorBrush}" />
                                    <TextBlock Text="{x:Bind ViewModel.DownloadSpeed, Mode=OneWay}" FontSize="13" FontWeight="SemiBold" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- 简易面积图 -->
                        <Canvas x:Name="SpeedChart" Grid.Row="1" Height="150"
                                SizeChanged="SpeedChart_SizeChanged"
                                PointerMoved="SpeedChart_PointerMoved"
                                PointerExited="SpeedChart_PointerExited" />

                        <!-- 底部连接数 / 运行时长 -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="16" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <fluent:SymbolIcon Symbol="PlugConnected" FontSize="11" Opacity="0.55" />
                                <TextBlock Text="{x:Bind ViewModel.ActiveConnections, Mode=OneWay}" FontSize="11" Opacity="0.65" />
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.RuntimeText, Mode=OneWay}" FontSize="11" Opacity="0.65" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 右侧：系统代理 + 虚拟网卡（等分拉伸，与左侧同高） -->
                <Grid Grid.Row="0" Grid.Column="1" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 系统代理 -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16,14,16,14"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid ColumnSpacing="12" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="3">
                                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                    <fluent:SymbolIcon Symbol="ArrowSwap" FontSize="14" Opacity="0.7" />
                                    <TextBlock Text="{Binding Source={StaticResource S}, Path=DashSystemProxy_Text}" FontWeight="SemiBold" FontSize="13" />
                                </StackPanel>
                                <TextBlock Text="选项" FontSize="11" Opacity="0.55" Margin="21,0,0,0" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" MinWidth="0" HorizontalAlignment="Right"
                                          IsOn="{x:Bind ViewModel.IsSystemProxyOn, Mode=TwoWay}"
                                          OffContent="" OnContent="" />
                        </Grid>
                    </Border>

                    <!-- 虚拟网卡 (TUN) -->
                    <Border Grid.Row="1"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16,14,16,14"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid ColumnSpacing="12" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="3">
                                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                    <fluent:SymbolIcon Symbol="Flashlight" FontSize="14" Opacity="0.7" />
                                    <TextBlock Text="虚拟网卡" FontWeight="SemiBold" FontSize="13" />
                                </StackPanel>
                                <TextBlock Text="选项" FontSize="11" Opacity="0.55" Margin="21,0,0,0" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" MinWidth="0" HorizontalAlignment="Right"
                                          IsOn="{x:Bind ViewModel.IsTunEnabled, Mode=OneWay}"
                                          OffContent="" OnContent=""
                                          Toggled="TunToggle_Toggled" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- ═══ 第二行：三张等宽卡片（出站模式 / 网络检测 / 流量统计） ═══ -->

                <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <!-- 出站模式 -->
                    <Border Grid.Column="0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <fluent:SymbolIcon Symbol="BranchFork" FontSize="14" Opacity="0.7" />
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=DashOutboundMode_Text}"
                                           Style="{StaticResource CardTitleStyle}" />
                            </StackPanel>
                            <RadioButton Grid.Row="1" Content="{Binding Source={StaticResource S}, Path=DashModeRule_Content}" GroupName="Mode"
                                         IsChecked="{x:Bind ViewModel.IsModeRule, Mode=TwoWay}" MinHeight="32" />
                            <RadioButton Grid.Row="2" Content="{Binding Source={StaticResource S}, Path=DashModeGlobal_Content}" GroupName="Mode"
                                         IsChecked="{x:Bind ViewModel.IsModeGlobal, Mode=TwoWay}" MinHeight="32" />
                            <RadioButton Grid.Row="3" Content="{Binding Source={StaticResource S}, Path=DashModeDirect_Content}" GroupName="Mode"
                                         IsChecked="{x:Bind ViewModel.IsModeDirect, Mode=TwoWay}" MinHeight="32" />
                        </Grid>
                    </Border>

                    <!-- 网络检测（合并了外部IP + 内网IP） -->
                    <Border Grid.Column="1"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <!-- 外部 IP 区域 -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                                <fluent:SymbolIcon Symbol="Globe" FontSize="14" Opacity="0.7" />
                                <TextBlock Text="网络检测" Style="{StaticResource CardTitleStyle}" />
                                <Button Padding="4,0" Background="Transparent" BorderThickness="0"
                                        ToolTipService.ToolTip="点击刷新 IP 检测"
                                        Command="{x:Bind ViewModel.CheckIpCommand}">
                                    <fluent:SymbolIcon Symbol="Info" FontSize="12" Opacity="0.45" />
                                </Button>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Border CornerRadius="4" Padding="6,3"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind ViewModel.CountryFlag, Mode=OneWay}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="White" />
                                </Border>
                                <TextBlock Text="{x:Bind ViewModel.ExternalIp, Mode=OneWay}"
                                           VerticalAlignment="Center" FontSize="13"
                                           IsTextSelectionEnabled="True" TextTrimming="CharacterEllipsis" />
                                <Button Padding="4" Background="Transparent" BorderThickness="0"
                                        VerticalAlignment="Center"
                                        Click="CopyExternalIp_Click"
                                        ToolTipService.ToolTip="{x:Bind ViewModel.ExternalIp, Mode=OneWay}">
                                    <fluent:SymbolIcon Symbol="Copy" FontSize="12" />
                                </Button>
                            </StackPanel>
                            <!-- 分隔线 -->
                            <Border Grid.Row="2" Height="1" Margin="0,6,0,6"
                                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" Opacity="0.4" />

                            <!-- 内网 IP 区域 -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                                <fluent:SymbolIcon Symbol="Router" FontSize="13" Opacity="0.65" />
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=DashLocalIp_Text}"
                                           Style="{StaticResource CardLabelStyle}" FontWeight="Normal" />
                            </StackPanel>
                            <TextBlock Grid.Row="4" Text="{x:Bind ViewModel.LocalIp, Mode=OneWay}"
                                       FontSize="14" FontWeight="SemiBold"
                                       IsTextSelectionEnabled="True" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Border>

                    <!-- 流量统计 -->
                    <Border Grid.Column="2"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <fluent:SymbolIcon Symbol="DataUsage" FontSize="14" Opacity="0.7" />
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=DashTrafficStats_Text}"
                                           Style="{StaticResource CardTitleStyle}" />
                            </StackPanel>

                            <!-- 上传行 -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,6,0,0">
                                <fluent:SymbolIcon Symbol="ArrowUpload" FontSize="13" Foreground="{StaticResource UploadIndicatorBrush}" />
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=DashTotalUpload_Text}"
                                           Style="{StaticResource CardLabelStyle}" />
                                <TextBlock Text="{x:Bind ViewModel.TotalUpload, Mode=OneWay}" FontWeight="SemiBold" FontSize="14" />
                            </StackPanel>

                            <!-- 下载行 -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10">
                                <fluent:SymbolIcon Symbol="ArrowDownload" FontSize="13" Foreground="{StaticResource DownloadIndicatorBrush}" />
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=DashTotalDownload_Text}"
                                           Style="{StaticResource CardLabelStyle}" />
                                <TextBlock Text="{x:Bind ViewModel.TotalDownload, Mode=OneWay}" FontWeight="SemiBold" FontSize="14" />
                            </StackPanel>

                            <!-- 连接数 -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="10">
                                <fluent:SymbolIcon Symbol="Link" FontSize="13" Opacity="0.6" />
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=DashActiveConnections_Text}"
                                           Style="{StaticResource CardLabelStyle}" />
                                <TextBlock Text="{x:Bind ViewModel.ActiveConnections, Mode=OneWay}" FontWeight="SemiBold" FontSize="14" />
                            </StackPanel>

                            <!-- 分隔线 -->
                            <Border Grid.Row="4" Height="1" Margin="0,4,0,4"
                                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" Opacity="0.35" />

                            <!-- 重置按钮 -->
                            <HyperlinkButton Grid.Row="5"
                                             Content="{Binding Source={StaticResource S}, Path=DashResetTraffic_Content}"
                                             FontSize="12" Padding="0"
                                             Command="{x:Bind ViewModel.ResetTrafficCommand}" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- 右下角悬浮启动按钮（FAB，唯一启动入口，状态联动色，悬停保持颜色） -->
        <Button x:Name="StartFab"
                Command="{x:Bind ViewModel.ToggleCoreCommand}"
                Width="56" Height="56" CornerRadius="28"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,28,28"
                Background="{x:Bind ViewModel.StartButtonBrush, Mode=OneWay}"
                ToolTipService.ToolTip="{x:Bind ViewModel.CoreToggleText, Mode=OneWay}">
            <Button.Resources>
                <!-- 覆盖默认悬停/按下行为：保持绑定背景色不变，仅缩放反馈 -->
                <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Grid x:Name="Root" Background="{TemplateBinding Background}"
                                      CornerRadius="{TemplateBinding CornerRadius}"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <ScaleTransform x:Name="ScaleXform" ScaleX="1" ScaleY="1" />
                                    </Grid.RenderTransform>
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ScaleXform"
                                                                     Storyboard.TargetProperty="ScaleX"
                                                                     To="1" Duration="0:0:0.15" />
                                                    <DoubleAnimation Storyboard.TargetName="ScaleXform"
                                                                     Storyboard.TargetProperty="ScaleY"
                                                                     To="1" Duration="0:0:0.15" />
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="PointerOver">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ScaleXform"
                                                                     Storyboard.TargetProperty="ScaleX"
                                                                     To="1.08" Duration="0:0:0.12" />
                                                    <DoubleAnimation Storyboard.TargetName="ScaleXform"
                                                                     Storyboard.TargetProperty="ScaleY"
                                                                     To="1.08" Duration="0:0:0.12" />
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Pressed">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ScaleXform"
                                                                     Storyboard.TargetProperty="ScaleX"
                                                                     To="0.95" Duration="0:0:0.08" />
                                                    <DoubleAnimation Storyboard.TargetName="ScaleXform"
                                                                     Storyboard.TargetProperty="ScaleY"
                                                                     To="0.95" Duration="0:0:0.08" />
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Disabled">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="Root"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="0.4" Duration="0:0:0.12" />
                                                </Storyboard>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding Content}" />
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Resources>
            <Grid>
                <fluent:SymbolIcon Symbol="Play" FontSize="22" Foreground="White"
                                   Visibility="{x:Bind ViewModel.IsRunning, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                <fluent:SymbolIcon Symbol="Pause" FontSize="22" Foreground="White"
                                   Visibility="{x:Bind ViewModel.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>
        </Button>
    </Grid>
</Page>
