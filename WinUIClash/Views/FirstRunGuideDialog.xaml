<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="WinUIClash.Views.FirstRunGuideDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    PrimaryButtonClick="OnPrimaryButtonClick"
    SecondaryButtonClick="OnSecondaryButtonClick">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMinWidth">420</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">520</x:Double>
    </ContentDialog.Resources>

    <Grid MinWidth="380" MaxWidth="480">

        <!-- 步骤 1：欢迎 + 快速上手 -->
        <StackPanel x:Name="Step1Panel" Spacing="12">
            <TextBlock x:Name="WelcomeTitle" Style="{ThemeResource SubtitleTextBlockStyle}" TextWrapping="Wrap" />
            <TextBlock x:Name="WelcomeSubtitle" Style="{ThemeResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <StackPanel Spacing="10" Margin="0,4,0,0">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE896;" FontSize="16" VerticalAlignment="Top"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                    <TextBlock x:Name="Step1Point1" Grid.Column="1" TextWrapping="Wrap"
                               Style="{ThemeResource BodyTextBlockStyle}" />
                </Grid>
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE774;" FontSize="16" VerticalAlignment="Top"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                    <TextBlock x:Name="Step1Point2" Grid.Column="1" TextWrapping="Wrap"
                               Style="{ThemeResource BodyTextBlockStyle}" />
                </Grid>
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE7F4;" FontSize="16" VerticalAlignment="Top"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                    <TextBlock x:Name="Step1Point3" Grid.Column="1" TextWrapping="Wrap"
                               Style="{ThemeResource BodyTextBlockStyle}" />
                </Grid>
            </StackPanel>
        </StackPanel>

        <!-- 步骤 2：一键导入订阅 -->
        <StackPanel x:Name="Step2Panel" Spacing="10" Visibility="Collapsed">
            <TextBlock x:Name="Step2Title" Style="{ThemeResource SubtitleTextBlockStyle}" TextWrapping="Wrap" />
            <TextBlock x:Name="Step2Hint" Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
            <TextBox x:Name="UrlBox" />
            <TextBox x:Name="NameBox" />
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Button x:Name="ImportButton" Click="OnImportClick" Style="{ThemeResource AccentButtonStyle}" />
                <ProgressRing x:Name="ImportRing" Width="20" Height="20" IsActive="False" Visibility="Collapsed" />
            </StackPanel>
            <TextBlock x:Name="ImportStatus" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Visibility="Collapsed" />
        </StackPanel>

        <!-- 步骤 3：基础设置 -->
        <StackPanel x:Name="Step3Panel" Spacing="16" Visibility="Collapsed">
            <TextBlock x:Name="Step3Title" Style="{ThemeResource SubtitleTextBlockStyle}" TextWrapping="Wrap" />

            <StackPanel Spacing="6">
                <TextBlock x:Name="ThemeLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <ComboBox x:Name="ThemeCombo" HorizontalAlignment="Stretch" />
            </StackPanel>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="2" VerticalAlignment="Center">
                    <TextBlock x:Name="AutoLaunchLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="AutoLaunchHint" Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
                <ToggleSwitch x:Name="AutoLaunchToggle" Grid.Column="1" MinWidth="0"
                              OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center" />
            </Grid>
        </StackPanel>

    </Grid>
</ContentDialog>
