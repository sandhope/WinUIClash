<Page
    x:Class="WinUIClash.Views.RequestsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fluent="using:FluentIcons.WinUI"
    xmlns:models="using:WinUIClash.Models"
    mc:Ignorable="d">

    <Grid Padding="24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Source={StaticResource S}, Path=RequestsTitle_Text}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            <AutoSuggestBox Grid.Column="1" Margin="16,0"
                            PlaceholderText="{Binding Source={StaticResource S}, Path=RequestsSearchPlaceholder_PlaceholderText}"
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <ToggleSwitch Header="{Binding Source={StaticResource S}, Path=RequestsAutoScroll_Text}"
                              OffContent="" OnContent=""
                              IsOn="{x:Bind ViewModel.AutoScroll, Mode=TwoWay}" />
                <Grid>
                    <Button Command="{x:Bind ViewModel.TogglePauseCommand}"
                            ToolTipService.ToolTip="{x:Bind ViewModel.PauseLabel, Mode=OneWay}"
                            Padding="8,4" Background="Transparent" BorderThickness="0"
                            Visibility="{x:Bind ViewModel.IsPaused, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <fluent:SymbolIcon Symbol="Pause" FontSize="12" />
                            <TextBlock Text="{x:Bind ViewModel.PauseLabel, Mode=OneWay}" FontSize="11" />
                        </StackPanel>
                    </Button>
                    <Button Command="{x:Bind ViewModel.TogglePauseCommand}"
                            ToolTipService.ToolTip="{x:Bind ViewModel.PauseLabel, Mode=OneWay}"
                            Padding="8,4" Background="Transparent" BorderThickness="0"
                            Visibility="{x:Bind ViewModel.IsPaused, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <fluent:SymbolIcon Symbol="Play" FontSize="12" />
                            <TextBlock Text="{x:Bind ViewModel.PauseLabel, Mode=OneWay}" FontSize="11" />
                        </StackPanel>
                    </Button>
                </Grid>
                <Button Command="{x:Bind ViewModel.CycleSortModeCommand}"
                        ToolTipService.ToolTip="{Binding Source={StaticResource S}, Path=ProxySwitchSort_Content}"
                        Padding="8,4" Background="Transparent" BorderThickness="0">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <fluent:SymbolIcon Symbol="ArrowSort" FontSize="12" />
                        <TextBlock Text="{x:Bind ViewModel.SortModeLabel, Mode=OneWay}" FontSize="11" />
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.ExportCommand}" ToolTipService.ToolTip="{Binding Source={StaticResource S}, Path=RequestsExport_ToolTip}">
                    <fluent:SymbolIcon Symbol="ArrowExport" FontSize="14" />
                </Button>
                <Button Command="{x:Bind ViewModel.ClearCommand}" ToolTipService.ToolTip="{Binding Source={StaticResource S}, Path=CommonClear_ToolTip}">
                    <fluent:SymbolIcon Symbol="Delete" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- 请求列表 -->
        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.FilteredRequests, Mode=OneWay}"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ConnectionInfo">
                    <Grid Padding="4,6" ColumnSpacing="10"
                          RightTapped="RequestItem_RightTapped"
                          DoubleTapped="RequestItem_DoubleTapped"
                          Tag="{x:Bind}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- 时间戳 -->
                        <TextBlock Text="{x:Bind Start, Converter={StaticResource DateTimeToTimeConverter}}"
                                   FontSize="10" Opacity="0.5" FontFamily="Consolas"
                                   VerticalAlignment="Center" Width="65" />
                        <!-- 主机 -->
                        <TextBlock Grid.Column="1" Text="{x:Bind Metadata.Host}"
                                   FontSize="12" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                        <!-- 进程名 -->
                        <TextBlock Grid.Column="2" Text="{x:Bind Metadata.Process}"
                                   FontSize="10" Opacity="0.5"
                                   VerticalAlignment="Center" MaxWidth="100"
                                   TextTrimming="CharacterEllipsis" />
                        <!-- 协议 -->
                        <Border Grid.Column="3" CornerRadius="3" Padding="4,1"
                                VerticalAlignment="Center"
                                Background="{ThemeResource SubtleFillColorSecondary}">
                            <TextBlock Text="{x:Bind Metadata.Network}"
                                       FontSize="10" FontWeight="SemiBold" Opacity="0.6" />
                        </Border>
                        <!-- 上传/下载 -->
                        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="10" FontFamily="Consolas" Opacity="0.6"
                                       VerticalAlignment="Center">
                                <Run Text="↑" /><Run Text="{x:Bind Upload, Converter={StaticResource BytesToStringConverter}}" />
                            </TextBlock>
                            <TextBlock FontSize="10" FontFamily="Consolas" Opacity="0.6"
                                       VerticalAlignment="Center">
                                <Run Text="↓" /><Run Text="{x:Bind Download, Converter={StaticResource BytesToStringConverter}}" />
                            </TextBlock>
                        </StackPanel>
                        <!-- 规则 -->
                        <TextBlock Grid.Column="5" Text="{x:Bind Rule}"
                                   FontSize="11" Opacity="0.6"
                                   VerticalAlignment="Center" MaxWidth="120"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 空状态 -->
        <StackPanel Grid.Row="1"
                    Visibility="{x:Bind ViewModel.FilteredRequests, Mode=OneWay, Converter={StaticResource EmptyCollectionToVisibilityConverter}}"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
            <fluent:SymbolIcon Symbol="ArrowSwap" FontSize="32" Opacity="0.3" />
            <TextBlock Text="{Binding Source={StaticResource S}, Path=EmptyRequests_Text}" Opacity="0.5" HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>
