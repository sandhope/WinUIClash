<Page
    x:Class="WinUIClash.Views.ProxiesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fluent="using:FluentIcons.WinUI"
    xmlns:models="using:WinUIClash.Models"
    mc:Ignorable="d">

    <Grid Padding="24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Uid="ProxyTitle" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            <AutoSuggestBox Grid.Column="1" Margin="16,0"
                            x:Uid="ProxySearch"
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <ComboBox ItemsSource="{x:Bind ViewModel.TestUrlLabels}"
                          SelectedIndex="{x:Bind ViewModel.SelectedTestUrlIndex, Mode=TwoWay}"
                          Width="130" FontSize="11"
                          ToolTipService.ToolTip="Test URL" />
                <Button Command="{x:Bind ViewModel.RefreshCommand}"
                        x:Uid="CommonRefresh"
                        Padding="8,4" Background="Transparent" BorderThickness="0">
                    <fluent:SymbolIcon Symbol="ArrowSync" FontSize="14" />
                </Button>
                <Button Command="{x:Bind ViewModel.TestAllDelaysCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <fluent:SymbolIcon Symbol="Gauge" FontSize="14" />
                        <TextBlock x:Uid="ProxyTestAll" FontSize="12" />
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.SelectBestCommand}"
                        Padding="8,4" Background="Transparent" BorderThickness="0">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <fluent:SymbolIcon Symbol="Star" FontSize="12" />
                        <TextBlock x:Uid="ProxySelectBest" FontSize="11" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 代理组 Tab 栏 + 排序 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsRepeater x:Name="GroupTabsRepeater"
                               ItemsSource="{x:Bind ViewModel.Groups, Mode=OneWay}"
                               ElementPrepared="GroupTabsRepeater_ElementPrepared">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Horizontal" Spacing="4" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:ProxyGroup">
                            <Button Padding="12,6" CornerRadius="6"
                                    Click="GroupTab_Click"
                                    Tag="{x:Bind}"
                                    ToolTipService.ToolTip="{x:Bind Now, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Bind NodeCountText}" FontSize="10" Opacity="0.4"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Bind Type}" FontSize="10" Opacity="0.5"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
            <Button Grid.Column="1" Command="{x:Bind ViewModel.CycleSortModeCommand}"
                    x:Uid="ProxySwitchSort"
                    Padding="8,4" Background="Transparent" BorderThickness="0">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <fluent:SymbolIcon Symbol="ArrowSort" FontSize="12" />
                    <TextBlock Text="{x:Bind ViewModel.SortModeLabel, Mode=OneWay}" FontSize="11" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- 测试进度条 -->
        <ProgressBar Grid.Row="2"
                     IsIndeterminate="False"
                     Minimum="0"
                     Maximum="{x:Bind ViewModel.TestTotal, Mode=OneWay}"
                     Value="{x:Bind ViewModel.TestProgress, Mode=OneWay}"
                     Visibility="{x:Bind ViewModel.IsTesting, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

        <!-- 延迟测试摘要 -->
        <TextBlock Grid.Row="3" FontSize="11" Opacity="0.5" Margin="0,-4,0,0"
                   Text="{x:Bind ViewModel.TestSummaryText, Mode=OneWay}"
                   Visibility="{x:Bind ViewModel.HasTestSummary, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

        <!-- 代理卡片网格 -->
        <GridView Grid.Row="4" x:Name="ProxyGrid"
                  ItemsSource="{x:Bind ViewModel.FilteredProxies, Mode=OneWay}"
                  SelectionMode="Single"
                  IsItemClickEnabled="True"
                  ItemClick="ProxyGrid_ItemClick"
                  ContainerContentChanging="ProxyGrid_ContainerContentChanging">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:Proxy">
                    <Border x:Name="CardBorder"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="12,10"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Width="180" MinHeight="70"
                            RightTapped="ProxyCard_RightTapped"
                            Tag="{x:Bind}">
                        <Grid RowSpacing="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="TypeDot" Width="6" Height="6"
                                         Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                         VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontSize="13"
                                           TextTrimming="CharacterEllipsis"
                                           FontWeight="SemiBold" />
                                <fluent:SymbolIcon x:Name="SelectedIcon" Grid.Column="2"
                                                    Symbol="CheckmarkCircle" FontSize="14"
                                                    Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                    Visibility="Collapsed" />
                            </Grid>
                            <TextBlock Grid.Row="1" Text="{x:Bind Type}" FontSize="11"
                                       Opacity="0.5" />
                            <TextBlock Grid.Row="2"
                                       Text="{x:Bind Delay, Mode=OneWay, Converter={StaticResource DelayToTextConverter}}"
                                       Foreground="{x:Bind Delay, Mode=OneWay, Converter={StaticResource DelayToColorConverter}}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Visibility="{x:Bind IsTestingDelay, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                            <ProgressRing Grid.Row="2"
                                          IsActive="{x:Bind IsTestingDelay, Mode=OneWay}"
                                          Visibility="{x:Bind IsTestingDelay, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                          Width="18" Height="18"
                                          HorizontalAlignment="Left" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <!-- 空状态 -->
        <StackPanel Grid.Row="4"
                    Visibility="{x:Bind ViewModel.FilteredProxies, Mode=OneWay, Converter={StaticResource EmptyCollectionToVisibilityConverter}}"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
            <fluent:SymbolIcon Symbol="Globe" FontSize="32" Opacity="0.3" />
            <TextBlock x:Uid="EmptyProxies" Opacity="0.5" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- 加载指示 -->
        <ProgressRing Grid.Row="2"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</Page>
