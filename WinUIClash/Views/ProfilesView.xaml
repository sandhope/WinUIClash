<Page
    x:Class="WinUIClash.Views.ProfilesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fluent="using:FluentIcons.WinUI"
    xmlns:models="using:WinUIClash.Models"
    mc:Ignorable="d">

    <Grid Padding="24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Uid="ProfilesTitle" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button x:Uid="ProfilesImport">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <fluent:SymbolIcon Symbol="AddSquare" FontSize="14" />
                        <TextBlock x:Uid="ProfilesImport" FontSize="12" />
                    </StackPanel>
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem x:Uid="ProfilesImportUrl" Click="ImportButton_Click">
                                <MenuFlyoutItem.Icon>
                                    <fluent:SymbolIcon Symbol="Link" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="ProfilesImportFile" Click="ImportFileButton_Click">
                                <MenuFlyoutItem.Icon>
                                    <fluent:SymbolIcon Symbol="DocumentAdd" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
                <Button Command="{x:Bind ViewModel.SyncAllCommand}"
                        x:Uid="CommonUpdateAll">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <fluent:SymbolIcon Symbol="ArrowSync" FontSize="14" />
                        <TextBlock x:Uid="CommonUpdateAll" FontSize="12" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 配置卡片网格 -->
        <GridView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="ProfileGrid_ItemClick">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:Profile">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Width="280" MinHeight="140">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- 标题行 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind Label, Mode=OneWay}" FontSize="14"
                                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                                <!-- 当前激活标识 -->
                                <Border Grid.Column="1"
                                        Visibility="{x:Bind IsActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Background="{StaticResource ActiveBadgeBrush}" CornerRadius="4"
                                        Padding="6,2"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Uid="ProfilesActive" FontSize="10" Foreground="White" />
                                </Border>
                            </Grid>

                            <!-- 订阅地址 -->
                            <TextBlock Grid.Row="1" FontSize="11" Opacity="0.6"
                                       Text="{x:Bind Url}" TextTrimming="CharacterEllipsis" />

                            <!-- 流量进度条 -->
                            <Grid Grid.Row="2" RowSpacing="4" Margin="0,4,0,0"
                                  Visibility="{x:Bind SubscriptionInfo, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ProgressBar Maximum="100" Value="{x:Bind UsedPercent, Mode=OneWay}" Height="4" />
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind UsedPercentText, Mode=OneWay}"
                                               FontSize="10" Opacity="0.5" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind RemainingText, Mode=OneWay}"
                                               FontSize="10" Opacity="0.5" />
                                </Grid>
                                <TextBlock Grid.Row="2" Text="{x:Bind ExpiryText, Mode=OneWay}"
                                           FontSize="10" Opacity="0.5"
                                           Foreground="{x:Bind ExpiryBrush, Mode=OneWay}" />
                            </Grid>

                            <!-- 底部操作 -->
                            <Grid Grid.Row="3" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind LastUpdate, Mode=OneWay, Converter={StaticResource DateTimeToRelativeConverter}}"
                                           FontSize="10" Opacity="0.4"
                                           VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                    <Button Padding="6" Background="Transparent" BorderThickness="0"
                                            x:Uid="CommonUpdate"
                                            Click="SyncButton_Click"
                                            Tag="{x:Bind}">
                                        <fluent:SymbolIcon Symbol="ArrowSync" FontSize="12" />
                                    </Button>
                                    <Button Padding="6" Background="Transparent" BorderThickness="0"
                                            x:Uid="ProfilesMore"
                                            Click="MoreButton_Click"
                                            Tag="{x:Bind}">
                                        <fluent:SymbolIcon Symbol="MoreHorizontal" FontSize="12" />
                                    </Button>
                                    <Button Padding="6" Background="Transparent" BorderThickness="0"
                                            x:Uid="CommonDelete"
                                            Click="DeleteButton_Click"
                                            Tag="{x:Bind}">
                                        <fluent:SymbolIcon Symbol="Delete" FontSize="12" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <!-- 空状态 -->
        <StackPanel Grid.Row="1"
                    Visibility="{x:Bind ViewModel.Profiles, Mode=OneWay, Converter={StaticResource EmptyCollectionToVisibilityConverter}}"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
            <fluent:SymbolIcon Symbol="Document" FontSize="32" Opacity="0.3" />
            <TextBlock x:Uid="EmptyProfiles" Opacity="0.5" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- 加载指示 -->
        <ProgressRing Grid.Row="1"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</Page>
