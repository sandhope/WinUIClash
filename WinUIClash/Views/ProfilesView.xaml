<Page
    x:Class="WinUIClash.Views.ProfilesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fluent="using:FluentIcons.WinUI"
    xmlns:models="using:WinUIClash.Models"
    mc:Ignorable="d">

    <Grid Padding="24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="配置" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Grid.Column="2" Command="{x:Bind ViewModel.SyncAllCommand}"
                    ToolTipService.ToolTip="全部更新">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <fluent:SymbolIcon Symbol="ArrowSync" FontSize="14" />
                    <TextBlock Text="全部更新" FontSize="12" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- 配置卡片网格 -->
        <GridView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="ProfileGrid_ItemClick">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:Profile">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Width="280" MinHeight="140">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- 标题行 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind Label}" FontSize="14"
                                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                                <!-- 当前激活标识 -->
                                <Border Grid.Column="1"
                                        Visibility="{x:Bind IsActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Background="#4CAF50" CornerRadius="4"
                                        Padding="6,2"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="使用中" FontSize="10" Foreground="White" />
                                </Border>
                            </Grid>

                            <!-- 订阅地址 -->
                            <TextBlock Grid.Row="1" FontSize="11" Opacity="0.6"
                                       Text="{x:Bind Url}" TextTrimming="CharacterEllipsis" />

                            <!-- 流量进度条 -->
                            <Grid Grid.Row="2" RowSpacing="4" Margin="0,4,0,0"
                                  Visibility="{x:Bind SubscriptionInfo, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ProgressBar Maximum="100" Value="{x:Bind UsedPercent, Mode=OneWay}" Height="4" />
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind UsedPercentText, Mode=OneWay}"
                                               FontSize="10" Opacity="0.5" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind RemainingText, Mode=OneWay}"
                                               FontSize="10" Opacity="0.5" />
                                </Grid>
                            </Grid>

                            <!-- 底部操作 -->
                            <Grid Grid.Row="3" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind LastUpdate, Mode=OneWay, Converter={StaticResource DateTimeToRelativeConverter}}"
                                           FontSize="10" Opacity="0.4"
                                           VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                    <Button Padding="6" Background="Transparent" BorderThickness="0"
                                            ToolTipService.ToolTip="更新"
                                            Click="SyncButton_Click"
                                            Tag="{x:Bind}">
                                        <fluent:SymbolIcon Symbol="ArrowSync" FontSize="12" />
                                    </Button>
                                    <Button Padding="6" Background="Transparent" BorderThickness="0"
                                            ToolTipService.ToolTip="删除"
                                            Click="DeleteButton_Click"
                                            Tag="{x:Bind}">
                                        <fluent:SymbolIcon Symbol="Delete" FontSize="12" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <!-- 加载指示 -->
        <ProgressRing Grid.Row="1"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</Page>
