<UserControl
    x:Class="WinUIClash.Views.DeveloperToolsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fluent="using:FluentIcons.WinUI"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="0,0,16,24">

            <!-- 说明 + 重新检测 -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Source={StaticResource S}, Path=DevToolsDesc_Text}"
                           FontSize="12" Opacity="0.6" TextWrapping="Wrap" VerticalAlignment="Center" />
                <Button Grid.Column="1" Command="{x:Bind ViewModel.DiagnoseAllCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <fluent:SymbolIcon Symbol="ArrowSync" FontSize="14" />
                        <TextBlock Text="{Binding Source={StaticResource S}, Path=DevToolsRefresh_Content}" FontSize="12" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- WSL 代理桥接 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=DevToolsWsl_Text}" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=DevToolsWslDesc_Text}" FontSize="11" Opacity="0.5" TextWrapping="Wrap" />
                        </StackPanel>
                        <fluent:SymbolIcon Grid.Column="1" Symbol="Checkmark" Foreground="Green"
                                          Visibility="{x:Bind ViewModel.WslResult.IsHealthy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <fluent:SymbolIcon Grid.Column="1" Symbol="Warning" Foreground="Orange"
                                          Visibility="{x:Bind ViewModel.WslResult.IsHealthy, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                    </Grid>
                    <TextBlock Text="{x:Bind ViewModel.WslResult.Message, Mode=OneWay}" FontSize="12" TextWrapping="Wrap" />
                    <TextBlock Text="{x:Bind ViewModel.WslResult.Detail, Mode=OneWay}" FontSize="11" Opacity="0.5" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{x:Bind ViewModel.ApplyWslCommand}">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=DevToolsApply_Content}" />
                        </Button>
                        <Button Command="{x:Bind ViewModel.ResetWslCommand}">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=DevToolsReset_Content}" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 终端代理环境变量 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=DevToolsTerminal_Text}" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=DevToolsTerminalDesc_Text}" FontSize="11" Opacity="0.5" TextWrapping="Wrap" />
                        </StackPanel>
                        <fluent:SymbolIcon Grid.Column="1" Symbol="Checkmark" Foreground="Green"
                                          Visibility="{x:Bind ViewModel.TerminalResult.IsHealthy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <fluent:SymbolIcon Grid.Column="1" Symbol="Warning" Foreground="Orange"
                                          Visibility="{x:Bind ViewModel.TerminalResult.IsHealthy, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                    </Grid>
                    <TextBlock Text="{x:Bind ViewModel.TerminalResult.Message, Mode=OneWay}" FontSize="12" TextWrapping="Wrap" />
                    <TextBlock Text="{x:Bind ViewModel.TerminalResult.Detail, Mode=OneWay}" FontSize="11" Opacity="0.5" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{x:Bind ViewModel.ApplyTerminalCommand}">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=DevToolsApply_Content}" />
                        </Button>
                        <Button Command="{x:Bind ViewModel.ResetTerminalCommand}">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=DevToolsReset_Content}" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Microsoft Store 回环豁免 -->
            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=DevToolsStore_Text}" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=DevToolsStoreDesc_Text}" FontSize="11" Opacity="0.5" TextWrapping="Wrap" />
                        </StackPanel>
                        <fluent:SymbolIcon Grid.Column="1" Symbol="Checkmark" Foreground="Green"
                                          Visibility="{x:Bind ViewModel.StoreResult.IsHealthy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <fluent:SymbolIcon Grid.Column="1" Symbol="Warning" Foreground="Orange"
                                          Visibility="{x:Bind ViewModel.StoreResult.IsHealthy, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                    </Grid>
                    <TextBlock Text="{x:Bind ViewModel.StoreResult.Message, Mode=OneWay}" FontSize="12" TextWrapping="Wrap" />
                    <TextBlock Text="{x:Bind ViewModel.StoreResult.Detail, Mode=OneWay}" FontSize="11" Opacity="0.5" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{x:Bind ViewModel.ApplyStoreCommand}">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=DevToolsApply_Content}" />
                        </Button>
                        <Button Command="{x:Bind ViewModel.ResetStoreCommand}">
                            <TextBlock Text="{Binding Source={StaticResource S}, Path=DevToolsReset_Content}" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
