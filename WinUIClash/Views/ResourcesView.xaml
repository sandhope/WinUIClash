<Page
    x:Class="WinUIClash.Views.ResourcesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fluent="using:FluentIcons.WinUI"
    xmlns:models="using:WinUIClash.Models"
    mc:Ignorable="d">

    <Grid Padding="24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock x:Uid="ResTitle" FontSize="20" FontWeight="SemiBold" />
                <TextBlock FontSize="12" Opacity="0.5" VerticalAlignment="Bottom">
                    <Run Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}" />
                    <Run x:Uid="ResCountSuffix" />
                </TextBlock>
            </StackPanel>
            <!-- 类型筛选 -->
            <ComboBox Grid.Column="1" Width="130" Margin="12,0,0,0"
                      x:Name="TypeFilterCombo"
                      SelectionChanged="TypeFilter_SelectionChanged"
                      FontSize="12" SelectedIndex="0">
                <ComboBoxItem x:Uid="ResFilterAll" Tag="ALL" />
                <ComboBoxItem x:Uid="ResFilterProxy" Tag="Proxy" />
                <ComboBoxItem x:Uid="ResFilterRule" Tag="Rule" />
            </ComboBox>
            <!-- 搜索框 -->
            <TextBox Grid.Column="3" Width="200" Margin="8,0,0,0"
                     x:Uid="ResSearchPlaceholder"
                     Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <!-- GeoIP/GeoSite 更新 -->
            <Button Grid.Column="4" Margin="8,0,0,0"
                    x:Uid="ResGeoUpdate">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <fluent:SymbolIcon Symbol="Globe" FontSize="14" />
                    <TextBlock x:Uid="ResGeoUpdate" FontSize="12" />
                </StackPanel>
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Uid="ResUpdateGeoIp" Click="UpdateGeoIp_Click">
                            <MenuFlyoutItem.Icon>
                                <fluent:SymbolIcon Symbol="GlobeLocation" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Uid="ResUpdateGeoSite" Click="UpdateGeoSite_Click">
                            <MenuFlyoutItem.Icon>
                                <fluent:SymbolIcon Symbol="GlobeSurface" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
            <!-- 全部更新 -->
            <Button Grid.Column="5" Margin="8,0,0,0"
                    Command="{x:Bind ViewModel.UpdateAllCommand}"
                    x:Uid="ResUpdateAll">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <fluent:SymbolIcon Symbol="ArrowSync" FontSize="14" />
                    <TextBlock x:Uid="ResUpdateAll" FontSize="12" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- 资源列表 -->
        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.FilteredProviders, Mode=OneWay}"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ExternalProvider">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16,12" Margin="0,0,0,8"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind Name}" FontSize="14" FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <!-- 类别标签 -->
                                    <Border CornerRadius="4" Padding="6,2"
                                            VerticalAlignment="Center">
                                        <Border.Background>
                                            <SolidColorBrush Color="{ThemeResource SubtleFillColorSecondary}" />
                                        </Border.Background>
                                        <TextBlock Text="{x:Bind Category}" FontSize="10"
                                                   FontFamily="Consolas" FontWeight="SemiBold"
                                                   Opacity="0.7" />
                                    </Border>
                                    <!-- 类型标签 -->
                                    <Border CornerRadius="4" Padding="6,2"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Type}" FontSize="10"
                                                   FontFamily="Consolas" Opacity="0.7" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <TextBlock FontSize="11" Opacity="0.5">
                                        <Run x:Uid="ResEntries" />
                                        <Run Text="{x:Bind Count}" />
                                    </TextBlock>
                                    <TextBlock FontSize="11" Opacity="0.4">
                                        <Run x:Uid="ResSource" />
                                        <Run Text="{x:Bind VehicleType}" />
                                    </TextBlock>
                                    <TextBlock FontSize="11" Opacity="0.3"
                                               Text="{x:Bind Path}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="300" />
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Grid.Column="1" FontSize="11" Opacity="0.5"
                                       Text="{x:Bind UpdateAt, Mode=OneWay, Converter={StaticResource DateTimeToRelativeConverter}}"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="2" Padding="8,4"
                                    x:Uid="ResUpdate"
                                    Click="UpdateProvider_Click"
                                    Tag="{x:Bind}">
                                <fluent:SymbolIcon Symbol="ArrowSync" FontSize="13" />
                            </Button>
                            <Button Grid.Column="3" Padding="8,4"
                                    x:Uid="ResHealthCheck"
                                    Click="HealthCheck_Click"
                                    Tag="{x:Bind}"
                                    Visibility="{x:Bind IsHealthChecking, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <fluent:SymbolIcon Symbol="HeartPulse" FontSize="13" />
                            </Button>
                            <ProgressRing Grid.Column="3" IsActive="{x:Bind IsHealthChecking, Mode=OneWay}"
                                          Visibility="{x:Bind IsHealthChecking, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                          Width="22" Height="22" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 空状态 -->
        <StackPanel Grid.Row="1"
                    Visibility="{x:Bind ViewModel.FilteredProviders, Mode=OneWay, Converter={StaticResource EmptyCollectionToVisibilityConverter}}"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
            <fluent:SymbolIcon Symbol="Database" FontSize="32" Opacity="0.3" />
            <TextBlock x:Uid="EmptyResources" Opacity="0.5" HorizontalAlignment="Center" />
        </StackPanel>

        <ProgressRing Grid.Row="1"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</Page>
