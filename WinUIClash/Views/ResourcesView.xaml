<Page
    x:Class="WinUIClash.Views.ResourcesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fluent="using:FluentIcons.WinUI"
    xmlns:models="using:WinUIClash.Models"
    mc:Ignorable="d">

    <Grid Padding="24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Grid RowSpacing="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Row="0" Grid.ColumnSpan="6" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{Binding Source={StaticResource S}, Path=ResTitle_Text}" FontSize="20" FontWeight="SemiBold" />
                <TextBlock FontSize="12" Opacity="0.5" VerticalAlignment="Bottom">
                    <Run Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}" />
                    <Run Text="{Binding Source={StaticResource S}, Path=ResCountSuffix_Text}" />
                </TextBlock>
            </StackPanel>
            <!-- 类型筛选 -->
            <ComboBox Grid.Row="1" Grid.Column="0" Width="130" Height="32" VerticalAlignment="Center"
                      x:Name="TypeFilterCombo"
                      SelectionChanged="TypeFilter_SelectionChanged"
                      FontSize="12" SelectedIndex="0">
                <ComboBoxItem Content="{Binding Source={StaticResource S}, Path=ResFilterAll_Content}" Tag="ALL" />
                <ComboBoxItem Content="{Binding Source={StaticResource S}, Path=ResFilterProxy_Content}" Tag="Proxy" />
                <ComboBoxItem Content="{Binding Source={StaticResource S}, Path=ResFilterRule_Content}" Tag="Rule" />
            </ComboBox>
            <!-- 搜索框 -->
            <AutoSuggestBox Grid.Row="1" Grid.Column="2" Width="200" Height="32" Margin="8,0,0,0" VerticalAlignment="Center"
                            PlaceholderText="{Binding Source={StaticResource S}, Path=ResSearchPlaceholder_PlaceholderText}"
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <!-- GeoIP/GeoSite 更新 -->
            <Button Grid.Row="1" Grid.Column="3" Margin="8,0,0,0" Height="32" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <fluent:SymbolIcon Symbol="Globe" FontSize="14" />
                    <TextBlock Text="{Binding Source={StaticResource S}, Path=ResGeoUpdate_Text}" FontSize="12" />
                </StackPanel>
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="{Binding Source={StaticResource S}, Path=ResUpdateGeoIp_Text}" Click="UpdateGeoIp_Click">
                            <MenuFlyoutItem.Icon>
                                <fluent:SymbolIcon Symbol="GlobeLocation" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="{Binding Source={StaticResource S}, Path=ResUpdateGeoSite_Text}" Click="UpdateGeoSite_Click">
                            <MenuFlyoutItem.Icon>
                                <fluent:SymbolIcon Symbol="GlobeSurface" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="{Binding Source={StaticResource S}, Path=ResUpdateMmdb_Text}" Click="UpdateMmdb_Click">
                            <MenuFlyoutItem.Icon>
                                <fluent:SymbolIcon Symbol="Database" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="{Binding Source={StaticResource S}, Path=ResUpdateAsn_Text}" Click="UpdateAsn_Click">
                            <MenuFlyoutItem.Icon>
                                <fluent:SymbolIcon Symbol="Server" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
            <!-- 全部更新 -->
            <Button Grid.Row="1" Grid.Column="4" Margin="8,0,0,0" Height="32" VerticalAlignment="Center"
                    Command="{x:Bind ViewModel.UpdateAllCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <fluent:SymbolIcon Symbol="ArrowSync" FontSize="14" />
                    <TextBlock Text="{Binding Source={StaticResource S}, Path=ResUpdateAll_Text}" FontSize="12" />
                </StackPanel>
            </Button>
            <!-- 刷新列表 -->
            <Button Grid.Row="1" Grid.Column="5" Margin="8,0,0,0" Height="32" VerticalAlignment="Center"
                    Command="{x:Bind ViewModel.RefreshCommand}"
                    ToolTipService.ToolTip="{Binding Source={StaticResource S}, Path=CommonRefresh_ToolTip}">
                <fluent:SymbolIcon Symbol="ArrowSync" FontSize="14" />
            </Button>
        </Grid>

        <!-- 更新进度 -->
        <TextBlock Grid.Row="1" VerticalAlignment="Top" Margin="0,0,0,-20"
                   FontSize="11" Opacity="0.6"
                   Text="{x:Bind ViewModel.UpdateAllProgressText, Mode=OneWay}"
                   Visibility="{x:Bind ViewModel.IsUpdatingAll, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

        <!-- 资源列表 -->
        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.FilteredProviders, Mode=OneWay}"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ExternalProvider">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16,12" Margin="0,0,0,8"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind Name}" FontSize="14" FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <!-- 类别标签 -->
                                    <Border CornerRadius="4" Padding="6,2"
                                            VerticalAlignment="Center">
                                        <Border.Background>
                                            <SolidColorBrush Color="{ThemeResource SubtleFillColorSecondary}" />
                                        </Border.Background>
                                        <TextBlock Text="{x:Bind Category}" FontSize="10"
                                                   FontFamily="Consolas" FontWeight="SemiBold"
                                                   Opacity="0.7" />
                                    </Border>
                                    <!-- 类型标签 -->
                                    <Border CornerRadius="4" Padding="6,2"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Type}" FontSize="10"
                                                   FontFamily="Consolas" Opacity="0.7" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <TextBlock FontSize="11" Opacity="0.5">
                                        <Run Text="{Binding Source={StaticResource S}, Path=ResEntries_Text}" />
                                        <Run Text="{x:Bind Count}" />
                                    </TextBlock>
                                    <TextBlock FontSize="11" Opacity="0.4">
                                        <Run Text="{Binding Source={StaticResource S}, Path=ResSource_Text}" />
                                        <Run Text="{x:Bind VehicleType}" />
                                    </TextBlock>
                                    <TextBlock FontSize="11" Opacity="0.3"
                                               Text="{x:Bind Path}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="300" />
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Grid.Column="1" FontSize="11" Opacity="0.5"
                                       Text="{x:Bind UpdateAt, Mode=OneWay, Converter={StaticResource DateTimeToRelativeConverter}}"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="2" Padding="8,4"
                                    ToolTipService.ToolTip="{Binding Source={StaticResource S}, Path=ResUpdate_ToolTip}"
                                    Click="UpdateProvider_Click"
                                    Tag="{x:Bind}">
                                <fluent:SymbolIcon Symbol="ArrowSync" FontSize="13" />
                            </Button>
                            <Button Grid.Column="3" Padding="8,4"
                                    ToolTipService.ToolTip="{Binding Source={StaticResource S}, Path=ResHealthCheck_ToolTip}"
                                    Click="HealthCheck_Click"
                                    Tag="{x:Bind}"
                                    Visibility="{x:Bind IsHealthChecking, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <fluent:SymbolIcon Symbol="HeartPulse" FontSize="13" />
                            </Button>
                            <ProgressRing Grid.Column="3" IsActive="{x:Bind IsHealthChecking, Mode=OneWay}"
                                          Visibility="{x:Bind IsHealthChecking, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                          Width="22" Height="22" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 空状态 -->
        <StackPanel Grid.Row="1"
                    Visibility="{x:Bind ViewModel.FilteredProviders, Mode=OneWay, Converter={StaticResource EmptyCollectionToVisibilityConverter}}"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
            <fluent:SymbolIcon Symbol="Database" FontSize="32" Opacity="0.3" />
            <TextBlock Text="{Binding Source={StaticResource S}, Path=EmptyResources_Text}" Opacity="0.5" HorizontalAlignment="Center" />
        </StackPanel>

        <ProgressRing Grid.Row="1"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</Page>
