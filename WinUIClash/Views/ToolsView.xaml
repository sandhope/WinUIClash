<Page
    x:Class="WinUIClash.Views.ToolsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fluent="using:FluentIcons.WinUI"
    mc:Ignorable="d">

    <Grid Padding="24,16">
        <!-- 主页：设置列表 -->
        <ScrollViewer x:Name="MainPanel"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{x:Bind ViewModel.IsSubPage, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <StackPanel Spacing="24">
                <TextBlock x:Uid="ToolsTitle" FontSize="20" FontWeight="SemiBold" />

                <!-- 设置区域 -->
                <TextBlock x:Uid="ToolsSettingsSection" FontSize="14" Opacity="0.6" Margin="0,0,0,-8" />
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.SettingsItems}"
                               ElementPrepared="ToolItem_ElementPrepared">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="4" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                    Click="SettingItem_Click" Tag="{Binding}"
                                    Padding="0" Background="Transparent" BorderThickness="0">
                                <Border Style="{StaticResource SettingsCardStyle}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <fluent:SymbolIcon x:Name="ItemIcon" Symbol="Settings" FontSize="18"
                                                           VerticalAlignment="Center" Opacity="0.7" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Subtitle}" FontSize="11" Opacity="0.5" />
                                        </StackPanel>
                                        <fluent:SymbolIcon Grid.Column="2" Symbol="ChevronRight"
                                                           FontSize="12" Opacity="0.4"
                                                           VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- 其他区域 -->
                <TextBlock x:Uid="ToolsOtherSection" FontSize="14" Opacity="0.6" Margin="0,8,0,-8" />
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.OtherItems}"
                               ElementPrepared="ToolItem_ElementPrepared">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="4" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                    Click="SettingItem_Click" Tag="{Binding}"
                                    Padding="0" Background="Transparent" BorderThickness="0">
                                <Border Style="{StaticResource SettingsCardStyle}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <fluent:SymbolIcon x:Name="ItemIcon" Symbol="Info" FontSize="18"
                                                           VerticalAlignment="Center" Opacity="0.7" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Subtitle}" FontSize="11" Opacity="0.5" />
                                        </StackPanel>
                                        <fluent:SymbolIcon Grid.Column="2" Symbol="ChevronRight"
                                                           FontSize="12" Opacity="0.4"
                                                           VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </ScrollViewer>

        <!-- 子页面 -->
        <Grid x:Name="SubPanel"
              Visibility="{x:Bind ViewModel.IsSubPage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 子页面标题栏 -->
            <Grid Padding="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Click="BackButton_Click"
                        Background="Transparent" BorderThickness="0"
                        Padding="4" Margin="-4,0,8,0"
                        x:Uid="ToolsBack"
                        ToolTipService.ToolTip="Back">
                    <fluent:SymbolIcon Symbol="ArrowLeft" FontSize="16" />
                </Button>
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.CurrentTitle, Mode=OneWay}"
                           FontSize="20" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </Grid>

            <!-- 子页面内容：手动管理 Content，避免 x:Bind 导致可视化树冲突 -->
            <ContentControl x:Name="SubPageContent" Grid.Row="1"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch" />
        </Grid>
    </Grid>
</Page>
