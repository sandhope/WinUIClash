<Page
    x:Class="WinUIClash.Views.ToolsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fluent="using:FluentIcons.WinUI"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 主页标题 -->
        <TextBlock Grid.Row="0" Text="{Binding Source={StaticResource S}, Path=ToolsTitle_Text}" FontSize="20" FontWeight="SemiBold" Margin="24,16,24,0"
                   Visibility="{x:Bind ViewModel.IsSubPage, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

        <!-- 主页：设置列表 -->
        <ScrollViewer Grid.Row="1" x:Name="MainPanel"
                      Padding="24,16,24,0"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{x:Bind ViewModel.IsSubPage, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <StackPanel Spacing="24">

                <!-- 设置区域 -->
                <TextBlock Text="{Binding Source={StaticResource S}, Path=ToolsSettingsSection_Text}" FontSize="14" Opacity="0.6" Margin="0,0,0,-8" />

                <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                        Click="SettingItem_Click" Tag="LanguageSettings"
                        Padding="0" Background="Transparent" BorderThickness="0">
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <fluent:SymbolIcon Symbol="Globe" FontSize="18" VerticalAlignment="Center" Opacity="0.7" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=SettingsLanguage_Text}" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=ToolsLanguageSub_Text}" FontSize="11" Opacity="0.5" />
                            </StackPanel>
                            <fluent:SymbolIcon Grid.Column="2" Symbol="ChevronRight" FontSize="12" Opacity="0.4" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Button>

                <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                        Click="SettingItem_Click" Tag="ThemeSettings"
                        Padding="0" Background="Transparent" BorderThickness="0">
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <fluent:SymbolIcon Symbol="Color" FontSize="18" VerticalAlignment="Center" Opacity="0.7" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=SettingsTheme_Text}" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=ToolsThemeSettingsSub_Text}" FontSize="11" Opacity="0.5" />
                            </StackPanel>
                            <fluent:SymbolIcon Grid.Column="2" Symbol="ChevronRight" FontSize="12" Opacity="0.4" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Button>

                <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                        Click="SettingItem_Click" Tag="BasicConfig"
                        Padding="0" Background="Transparent" BorderThickness="0">
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <fluent:SymbolIcon Symbol="Settings" FontSize="18" VerticalAlignment="Center" Opacity="0.7" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=SettingsBasicConfig_Text}" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=ToolsBasicConfigSub_Text}" FontSize="11" Opacity="0.5" />
                            </StackPanel>
                            <fluent:SymbolIcon Grid.Column="2" Symbol="ChevronRight" FontSize="12" Opacity="0.4" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Button>

                <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                        Click="SettingItem_Click" Tag="AppSettings"
                        Padding="0" Background="Transparent" BorderThickness="0">
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <fluent:SymbolIcon Symbol="AppGeneric" FontSize="18" VerticalAlignment="Center" Opacity="0.7" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=SettingsApp_Text}" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=ToolsAppSettingsSub_Text}" FontSize="11" Opacity="0.5" />
                            </StackPanel>
                            <fluent:SymbolIcon Grid.Column="2" Symbol="ChevronRight" FontSize="12" Opacity="0.4" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Button>

                <!-- 其他区域 -->
                <TextBlock Text="{Binding Source={StaticResource S}, Path=ToolsOtherSection_Text}" FontSize="14" Opacity="0.6" Margin="0,8,0,-8" />

                <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                        Click="SettingItem_Click" Tag="DeveloperTools"
                        Padding="0" Background="Transparent" BorderThickness="0">
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <fluent:SymbolIcon Symbol="Toolbox" FontSize="18" VerticalAlignment="Center" Opacity="0.7" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=DevToolsTitle_Text}" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=DevToolsCardSub_Text}" FontSize="11" Opacity="0.5" />
                            </StackPanel>
                            <fluent:SymbolIcon Grid.Column="2" Symbol="ChevronRight" FontSize="12" Opacity="0.4" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Button>

                <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                        Click="SettingItem_Click" Tag="About"
                        Padding="0" Background="Transparent" BorderThickness="0">
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <fluent:SymbolIcon Symbol="Info" FontSize="18" VerticalAlignment="Center" Opacity="0.7" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=SettingsAbout_Text}" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=ToolsAboutSub_Text}" FontSize="11" Opacity="0.5" />
                            </StackPanel>
                            <fluent:SymbolIcon Grid.Column="2" Symbol="ChevronRight" FontSize="12" Opacity="0.4" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Button>

                <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                        Click="SettingItem_Click" Tag="Shortcuts"
                        Padding="0" Background="Transparent" BorderThickness="0">
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <fluent:SymbolIcon Symbol="Keyboard" FontSize="18" VerticalAlignment="Center" Opacity="0.7" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=NavShortcuts_Content}" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Source={StaticResource S}, Path=ToolsShortcutsSub_Text}" FontSize="11" Opacity="0.5" />
                            </StackPanel>
                            <fluent:SymbolIcon Grid.Column="2" Symbol="ChevronRight" FontSize="12" Opacity="0.4" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Button>
            </StackPanel>
        </ScrollViewer>

        <!-- 子页面 -->
        <Grid Grid.Row="0" Grid.RowSpan="2" x:Name="SubPanel"
              Padding="24,16"
              Visibility="{x:Bind ViewModel.IsSubPage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 子页面标题栏 -->
            <Grid Padding="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Click="BackButton_Click"
                        Background="Transparent" BorderThickness="0"
                        Padding="4" Margin="-4,0,8,0"
                        ToolTipService.ToolTip="{Binding Source={StaticResource S}, Path=ToolsBack_ToolTip}">
                    <fluent:SymbolIcon Symbol="ArrowLeft" FontSize="16" />
                </Button>
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.CurrentTitle, Mode=OneWay}"
                           FontSize="20" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </Grid>

            <!-- 子页面内容：手动管理 Content，避免 x:Bind 导致可视化树冲突 -->
            <ContentControl x:Name="SubPageContent" Grid.Row="1"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch" />
        </Grid>
    </Grid>
</Page>
