<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WinUIClash.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUIClash"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fluent="using:FluentIcons.WinUI"
    mc:Ignorable="d"
    Title="WinUIClash">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 通知 InfoBar 浮层 -->
        <InfoBar x:Name="NotificationBar"
                 Canvas.ZIndex="100"
                 VerticalAlignment="Top"
                 Margin="24,8"
                 IsOpen="False"
                 IsClosable="True" />

        <NavigationView
            x:Name="RootNavigation"
            PaneDisplayMode="Left"
            IsPaneToggleButtonVisible="False"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            AlwaysShowHeader="False"
            OpenPaneLength="200"
            SelectionChanged="RootNavigation_SelectionChanged">

            <NavigationView.PaneHeader>
                <StackPanel Margin="16,12,12,8" Spacing="8">
                    <TextBlock
                        Text="WinUIClash"
                        FontSize="16"
                        FontWeight="SemiBold" />
                    <AutoSuggestBox
                        x:Name="SearchBox"
                        x:Uid="SearchBox"
                        QueryIcon="Find"
                        TextChanged="SearchBox_TextChanged"
                        SuggestionChosen="SearchBox_SuggestionChosen"
                        FontSize="12" />
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <!-- 仪表盘 -->
                <NavigationViewItem x:Uid="NavDashboard" Tag="Dashboard">
                    <NavigationViewItem.Icon>
                        <fluent:SymbolIcon Symbol="Home" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <!-- 代理 -->
                <NavigationViewItem x:Uid="NavProxies" Tag="Proxies">
                    <NavigationViewItem.Icon>
                        <fluent:SymbolIcon Symbol="Globe" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <!-- 配置 -->
                <NavigationViewItem x:Uid="NavProfiles" Tag="Profiles">
                    <NavigationViewItem.Icon>
                        <fluent:SymbolIcon Symbol="Folder" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <!-- 请求 -->
                <NavigationViewItem x:Uid="NavRequests" Tag="Requests">
                    <NavigationViewItem.Icon>
                        <fluent:SymbolIcon Symbol="List" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <!-- 连接 -->
                <NavigationViewItem x:Uid="NavConnections" Tag="Connections">
                    <NavigationViewItem.Icon>
                        <fluent:SymbolIcon Symbol="Link" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <!-- 资源 -->
                <NavigationViewItem x:Uid="NavResources" Tag="Resources">
                    <NavigationViewItem.Icon>
                        <fluent:SymbolIcon Symbol="Library" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <!-- 规则 -->
                <NavigationViewItem x:Uid="NavRules" Tag="Rules">
                    <NavigationViewItem.Icon>
                        <fluent:SymbolIcon Symbol="Filter" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <!-- 日志 -->
                <NavigationViewItem x:Uid="NavLogs" Tag="Logs">
                    <NavigationViewItem.Icon>
                        <fluent:SymbolIcon Symbol="Notepad" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <!-- 工具 -->
                <NavigationViewItem x:Uid="NavTools" Tag="Tools">
                    <NavigationViewItem.Icon>
                        <fluent:SymbolIcon Symbol="Wrench" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.PaneFooter>
                <Button
                    x:Name="SidebarToggleButton"
                    Click="SidebarToggleButton_Click"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,16"
                    Background="Transparent"
                    BorderThickness="0">
                    <fluent:SymbolIcon Symbol="Navigation" />
                </Button>
            </NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <!-- 底部状态栏 -->
        <Grid Grid.Row="1" Height="28"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 核心状态 (可点击切换) -->
            <Button Background="Transparent" BorderThickness="0" Padding="0"
                    Click="StatusDot_Click" x:Uid="StatusToggle">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                            Margin="12,0,16,0">
                    <Ellipse Width="8" Height="8" x:Name="StatusDot"
                             Fill="{ThemeResource SystemFillColorCritical}" />
                    <TextBlock x:Uid="StatusStopped" FontSize="11" x:Name="StatusText"
                               Opacity="0.6" />
                </StackPanel>
            </Button>

            <Border Grid.Column="1" Width="1" Margin="4,4"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- 活跃连接数 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                        VerticalAlignment="Center" Margin="12,0,8,0">
                <fluent:SymbolIcon Symbol="Link" FontSize="10" Opacity="0.5" />
                <TextBlock Text="0" FontSize="11" x:Name="ConnectionCountText"
                           FontFamily="Consolas" Opacity="0.5" />
            </StackPanel>

            <!-- 上传/下载速度 -->
            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="12"
                        VerticalAlignment="Center" Margin="12,0">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <fluent:SymbolIcon Symbol="ArrowUp" FontSize="10" />
                    <TextBlock Text="0 B/s" FontSize="11" x:Name="UploadSpeedText"
                               FontFamily="Consolas" Opacity="0.6" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <fluent:SymbolIcon Symbol="ArrowDown" FontSize="10" />
                    <TextBlock Text="0 B/s" FontSize="11" x:Name="DownloadSpeedText"
                               FontFamily="Consolas" Opacity="0.6" />
                </StackPanel>
            </StackPanel>

            <!-- 系统代理状态 -->
            <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6"
                        VerticalAlignment="Center" Margin="0,0,12,0">
                <fluent:SymbolIcon Symbol="ShieldCheckmark" FontSize="10"
                                   x:Name="ProxyIcon" Opacity="0.3" />
                <TextBlock x:Uid="StatusProxyLabel" FontSize="11" x:Name="ProxyText"
                           Opacity="0.3" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
