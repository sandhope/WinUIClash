<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WinUIClash.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUIClash"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fluent="using:FluentIcons.WinUI"
    mc:Ignorable="d"
    Title="WinUIClash">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" KeyboardAcceleratorPlacementMode="Hidden">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 自定义标题栏：接管非客户区，跟随应用明暗主题（修复深色模式下顶部仍为浅色） -->
        <TitleBar x:Name="AppTitleBar"
                  Title="WinUIClash"
                  Grid.Row="0">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <InfoBar x:Name="NotificationBar"
                 Grid.Row="1"
                 Canvas.ZIndex="100"
                 VerticalAlignment="Top"
                 Margin="24,8"
                 IsOpen="False"
                 IsClosable="True" />


        <NavigationView
            x:Name="RootNavigation"
            Grid.Row="1"
            PaneDisplayMode="Left"
            OpenPaneLength="200"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            AlwaysShowHeader="False"
            SelectionChanged="RootNavigation_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="{Binding Source={StaticResource S}, Path=NavDashboard_Content}" Tag="Dashboard">
                    <NavigationViewItem.Icon>
                        <fluent:SymbolIcon Symbol="Home" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{Binding Source={StaticResource S}, Path=NavProxies_Content}" Tag="Proxies">
                    <NavigationViewItem.Icon>
                        <fluent:SymbolIcon Symbol="Globe" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{Binding Source={StaticResource S}, Path=NavProfiles_Content}" Tag="Profiles">
                    <NavigationViewItem.Icon>
                        <fluent:SymbolIcon Symbol="Folder" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{Binding Source={StaticResource S}, Path=NavRequests_Content}" Tag="Requests">
                    <NavigationViewItem.Icon>
                        <fluent:SymbolIcon Symbol="List" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{Binding Source={StaticResource S}, Path=NavConnections_Content}" Tag="Connections">
                    <NavigationViewItem.Icon>
                        <fluent:SymbolIcon Symbol="Link" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{Binding Source={StaticResource S}, Path=NavResources_Content}" Tag="Resources">
                    <NavigationViewItem.Icon>
                        <fluent:SymbolIcon Symbol="Library" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{Binding Source={StaticResource S}, Path=NavLogs_Content}" Tag="Logs">
                    <NavigationViewItem.Icon>
                        <fluent:SymbolIcon Symbol="Notepad" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="{Binding Source={StaticResource S}, Path=NavTools_Content}" Tag="Tools">
                    <NavigationViewItem.Icon>
                        <fluent:SymbolIcon Symbol="Wrench" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <Grid Grid.Row="2" Height="28"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Background="Transparent" BorderThickness="0" Padding="0"
                    Click="StatusDot_Click"
                    ToolTipService.ToolTip="{Binding Source={StaticResource S}, Path=StatusToggle_ToolTip}">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                            Margin="12,0,16,0">
                    <Ellipse Width="8" Height="8" x:Name="StatusDot"
                             Fill="{ThemeResource SystemFillColorCritical}" />
                    <TextBlock Text="{Binding Source={StaticResource S}, Path=StatusStopped_Text}" FontSize="11" x:Name="StatusText"
                               Opacity="0.6" />
                </StackPanel>
            </Button>

            <Border Grid.Column="1" Width="1" Margin="4,4"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                        VerticalAlignment="Center" Margin="8,0">
                <fluent:SymbolIcon Symbol="Timer" FontSize="10" Opacity="0.5" />
                <TextBlock Text="" FontSize="11" x:Name="RuntimeText"
                           FontFamily="Consolas" Opacity="0.5" />
            </StackPanel>

            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4"
                        VerticalAlignment="Center" Margin="8,0,8,0">
                <fluent:SymbolIcon Symbol="Link" FontSize="10" Opacity="0.5" />
                <TextBlock Text="0" FontSize="11" x:Name="ConnectionCountText"
                           FontFamily="Consolas" Opacity="0.5" />
            </StackPanel>

            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="4"
                        VerticalAlignment="Center" Margin="4,0">
                <fluent:SymbolIcon Symbol="Storage" FontSize="10" Opacity="0.5" />
                <TextBlock Text="--" FontSize="11" x:Name="MemoryUsageText"
                           FontFamily="Consolas" Opacity="0.5" />
            </StackPanel>

            <Border Grid.Column="5" CornerRadius="3" Padding="6,2"
                    VerticalAlignment="Center" Margin="4,0"
                    Background="{ThemeResource SubtleFillColorSecondary}">
                <TextBlock Text="Rule" FontSize="10" FontWeight="SemiBold"
                           x:Name="OutboundModeText" Opacity="0.6" />
            </Border>

            <StackPanel Grid.Column="7" Orientation="Horizontal" Spacing="12"
                        VerticalAlignment="Center" Margin="12,0">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <fluent:SymbolIcon Symbol="ArrowUp" FontSize="10" />
                    <TextBlock Text="0 B/s" FontSize="11" x:Name="UploadSpeedText"
                               FontFamily="Consolas" Opacity="0.6" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <fluent:SymbolIcon Symbol="ArrowDown" FontSize="10" />
                    <TextBlock Text="0 B/s" FontSize="11" x:Name="DownloadSpeedText"
                               FontFamily="Consolas" Opacity="0.6" />
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="8" Background="Transparent" BorderThickness="0" Padding="0"
                    Click="StatusProxy_Click">
                <StackPanel Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center" Margin="4,0,12,0">
                    <fluent:SymbolIcon Symbol="ShieldCheckmark" FontSize="10"
                                       x:Name="ProxyIcon" Opacity="0.3" />
                    <TextBlock Text="{Binding Source={StaticResource S}, Path=StatusProxyLabel_Text}" FontSize="11" x:Name="ProxyText"
                               Opacity="0.3" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>